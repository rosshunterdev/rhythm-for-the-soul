---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist — but the rhythm does. Head back to Rhythm for the Soul."
>
  <section class="min-h-[70vh] flex items-center py-20 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

      <!-- Decorative drum rings -->
      <div class="flex justify-center mb-10" aria-hidden="true">
        <svg class="w-40 h-40 text-sage/20" viewBox="0 0 160 160" fill="none">
          <circle cx="80" cy="80" r="76" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="80" cy="80" r="60" stroke="currentColor" stroke-width="1"/>
          <circle cx="80" cy="80" r="44" stroke="#C4933F" stroke-width="1" opacity="0.4"/>
          <circle cx="80" cy="80" r="28" stroke="currentColor" stroke-width="1"/>
          <circle cx="80" cy="80" r="12" fill="#C4933F" opacity="0.25"/>
          <text
            x="80" y="86"
            text-anchor="middle"
            font-family="Georgia, serif"
            font-size="28"
            font-weight="600"
            fill="#C4933F"
            opacity="0.9"
          >404</text>
        </svg>
      </div>

      <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-4">Lost the beat</p>
      <h1 class="font-heading text-4xl lg:text-5xl font-semibold text-charcoal mb-5">
        This page has isn't here yet
      </h1>
      <p class="text-charcoal/60 text-lg leading-relaxed mb-10 max-w-lg mx-auto">
        The page you're looking for doesn't exist currently.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-7 py-3.5 bg-gold text-cream rounded-full font-medium text-sm hover:bg-gold-dark transition-colors shadow-sm"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Back to home
        </a>
        <a
          href="/contact"
          class="inline-flex items-center px-7 py-3.5 rounded-full font-medium text-sm border border-charcoal/25 text-charcoal hover:border-charcoal/50 hover:bg-charcoal/5 transition-colors"
        >
          Get in touch
        </a>
      </div>

      <!-- Quick nav -->
      <div class="mt-14 pt-10 border-t border-linen">
        <p class="text-xs font-medium text-charcoal/40 uppercase tracking-widest mb-6">Or jump to a programme</p>
        <div class="flex flex-wrap justify-center gap-3">
          {[
            { label: 'DRUMBEAT', href: '/drumbeat' },
            { label: 'Schools', href: '/schools' },
            { label: 'Rest Homes', href: '/rest-homes' },
            { label: 'Corporate', href: '/corporate' },
            { label: 'Events', href: '/events' },
            { label: 'About', href: '/about' },
          ].map(link => (
            <a
              href={link.href}
              class="px-4 py-2 rounded-full bg-linen text-charcoal/70 text-sm hover:bg-sage/15 hover:text-forest transition-colors"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
