---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import SpotifyEmbed from '../components/SpotifyEmbed.astro';
import ContactForm from '../components/ContactForm.astro';


const audienceDoors = [
  {
    title: 'For Schools & Educators',
    description: 'Creative percussion workshops that build teamwork, listening, and cultural connection. Curriculum-linked and available for all year levels.',
    href: '/schools',
    eyebrow: 'Education',
    theme: 'forest' as const,
  },
  {
    title: 'For Rest Homes & Aged Care',
    description: 'Joyful, gentle drumming sessions that lift mood, spark memories, and build meaningful connections in residential care settings.',
    href: '/rest-homes',
    eyebrow: 'Wellbeing',
    theme: 'sage' as const,
  },
  {
    title: 'For Workplaces & Teams',
    description: 'High-energy team building through the universal language of rhythm. No experience needed — just a willingness to have fun.',
    href: '/corporate',
    eyebrow: 'Corporate',
    theme: 'charcoal' as const,
  },
  {
    title: 'For Events & Individuals',
    description: 'Birthday parties, sound journeys, fire shows, laughter yoga, and 1-on-1 sessions — rhythm for every occasion.',
    href: '/events',
    eyebrow: 'Events',
    theme: 'linen' as const,
  },
];

const testimonials = [
  {
    quote: "Chewy has an extraordinary gift for meeting people where they are. Our students who rarely engage in group activities were drumming together within minutes — it was genuinely moving to watch.",
    author: "Aroha Tūhoe",
    role: "Head of Wellbeing",
    organization: "Northcote College",
    featured: true,
  },
  {
    quote: "The residents absolutely light up when Chewy arrives. Some of our quieter residents become the most enthusiastic participants — rhythm reaches places that words can't.",
    author: "Margaret Collins",
    role: "Activities Coordinator",
    organization: "Bayswater Rest Home",
  },
  {
    quote: "We've tried lots of team-building activities over the years, but nothing has come close to the energy and genuine laughter that came out of our drumming session. Highly recommend.",
    author: "David Park",
    role: "People & Culture Manager",
    organization: "Auckland tech company",
  },
];
---

<BaseLayout
  title="Rhythm for Everyone"
  description="Rhythm for the Soul — drumming workshops, music therapy, and live entertainment on Auckland's North Shore. Led by Julian 'Chewy', connecting communities through the power of rhythm."
>

  <!-- ── Hero ───────────────────────────────────────────── -->
  <section class="hero" aria-label="Introduction">

    <!-- Photo layer: full-bleed, amber overlay via ::before/::after -->
    <div class="hero-photo" aria-hidden="true"></div>

    <!-- Charcoal panel: diagonal clip-path, sibling of content -->
    <div class="hero-panel" aria-hidden="true"></div>

    <!-- Content: z-index above panel, max-width keeps text clear of diagonal -->
    <div class="hero-inner">
      <div class="hero-content">

        <p class="hero-pill">
          <span class="hero-pill-dot" aria-hidden="true"></span>
          Booking now — Auckland &amp; North Shore
        </p>

        <h1 class="display-heading">
          Rhythm
          <em class="display-accent">for everyone</em>
        </h1>

        <div class="hero-rule" aria-hidden="true"></div>

        <p class="sub-head">
          Drumming workshops, music therapy, laughter yoga and fire shows — for
          schools, rest homes, disability services and corporate events.
        </p>

        <div class="ctas">
          <a href="/drumbeat" class="cta-fill">
            Explore Programmes
            <svg class="cta-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/contact" class="cta-outline">Get in Touch</a>
        </div>

        <p class="hero-attribution">
          Led by <span class="hero-attribution-name">Julian &ldquo;Chewy&rdquo;</span>
          <span class="hero-attribution-sep" aria-hidden="true">·</span>
          <span class="hero-attribution-loc">10+ years on the North Shore</span>
        </p>

      </div>
    </div>

    <a href="#meet-chewy" class="hero-scroll" aria-label="Scroll to meet Chewy">
      <span class="hero-scroll-label">Meet Chewy</span>
      <span class="hero-scroll-chevron" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
        </svg>
      </span>
    </a>

  </section>

  <!-- ── Meet Chewy ─────────────────────────────────────── -->
  <section class="meet-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="meet-grid">

        <div class="reveal">
          <img
            src="/images/chewy-about.png"
            alt="Julian 'Chewy' facilitating a drumming session with participants"
            class="meet-img"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="reveal reveal-delay-1">
          <p class="meet-eyebrow">About Chewy</p>
          <h2 class="meet-heading">Meet Chewy</h2>
          <p class="meet-body">Julian — known to everyone as Chewy — is a professional drummer, music therapist and community performer based on Auckland's North Shore. With over a decade of experience, he has brought rhythm into schools, rest homes, disability services and boardrooms across the region.</p>
          <p class="meet-body">His sessions are inclusive by design: no experience needed, no performance pressure. Just the simple, powerful act of making music together.</p>
          <a href="/about" class="meet-link">More about Chewy</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── In action ──────────────────────────────────────── -->
  <div class="video-section max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="video-label-row reveal">
      <span class="video-divider"></span>
      <p class="video-label">See us in action</p>
      <span class="video-divider"></span>
    </div>
    <div class="reveal reveal-delay-1">
      <YouTubeEmbed
        videoId="dQw4w9WgXcQ"
        title="Rhythm for the Soul — watch a drumming session with Chewy"
        caption="Placeholder video — Chewy's own footage coming soon"
      />
    </div>
  </div>

  <!-- ── Audience doors ─────────────────────────────────── -->
  <section class="py-20 lg:py-28 bg-sage-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Who it's for</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">
          Rhythm meets everyone where they are
        </h2>
        <p class="text-charcoal/60 mt-3 max-w-xl mx-auto">
          From classrooms to boardrooms, rest homes to birthday parties — there's a programme designed for your group.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 lg:gap-5">
        {audienceDoors.map((card, i) => (
          <div class:list={['reveal', `reveal-delay-${i + 1}`]}>
            <ServiceCard {...card} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── DRUMBEAT feature ───────────────────────────────── -->
  <section class="py-20 lg:py-28 bg-linen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal">
          <!-- Decorative drum icon -->
          <div class="w-16 h-16 rounded-2xl bg-forest/10 flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-forest" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5">
              <ellipse cx="24" cy="16" rx="18" ry="8" />
              <line x1="6" y1="16" x2="6" y2="32"/>
              <line x1="42" y1="16" x2="42" y2="32"/>
              <ellipse cx="24" cy="32" rx="18" ry="8" />
            </svg>
          </div>
          <p class="text-xs font-medium text-forest uppercase tracking-widest mb-3">Featured Programme</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-4">
            DRUMBEAT — discovering rhythm, unity & transformation
          </h2>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            DRUMBEAT is an evidence-based group music therapy programme using hand drumming to support young people's social-emotional wellbeing, resilience, and sense of belonging.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-8">
            Developed for at-risk youth and delivered in school and community settings, it creates a non-judgmental space where every voice — and every beat — counts.
          </p>
          <a href="/drumbeat" class="inline-flex items-center gap-2 px-7 py-3.5 bg-forest text-cream rounded-full font-medium text-sm hover:bg-charcoal transition-colors shadow-sm">
            Discover DRUMBEAT
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Stats / highlights -->
        <div class="reveal reveal-delay-2 grid grid-cols-2 gap-4">
          {[
            { stat: '10+', label: 'Years facilitating' },
            { stat: '500+', label: 'Sessions delivered' },
            { stat: '20+', label: 'Instruments used' },
            { stat: 'NZ-wide', label: 'Reach & impact' },
          ].map(item => (
            <div class="rounded-2xl bg-cream border border-linen p-6 text-center">
              <p class="font-heading text-4xl font-semibold text-forest mb-1">{item.stat}</p>
              <p class="text-sm text-charcoal/60">{item.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── About teaser ───────────────────────────────────── -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Image placeholder -->
        <div class="reveal order-2 lg:order-1">
          <div class="rounded-3xl bg-linen aspect-[4/5] flex items-center justify-center relative overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="w-24 h-24 text-sage/30" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="0.75">
                <circle cx="24" cy="24" r="22"/>
                <circle cx="24" cy="24" r="16"/>
                <circle cx="24" cy="24" r="10"/>
                <circle cx="24" cy="24" r="4" fill="currentColor"/>
              </svg>
            </div>
            <p class="relative text-stone/50 text-sm text-center px-8">Photo of Chewy<br/><span class="text-xs">Image coming soon</span></p>
          </div>
        </div>

        <!-- Text -->
        <div class="reveal reveal-delay-2 order-1 lg:order-2">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Meet your facilitator</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">
            Hi, I'm Chewy
          </h2>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            I'm Julian — most people call me Chewy. I'm a drumming facilitator, music therapist, and performer based on Auckland's North Shore, and I believe deeply in the power of rhythm to heal, connect, and transform.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            Over the years I've worked with young people in schools, older adults in rest homes, teams in boardrooms, and individuals seeking something that words alone can't offer. The instruments change — djembes, handpans, didgeridoos, native flutes — but the experience of coming together through rhythm is always the same: immediate, joyful, and real.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-8">
            I work across Auckland's North Shore and surrounds, and I'd love to bring that energy to your group.
          </p>
          <a href="/about" class="inline-flex items-center gap-2 text-forest font-medium text-sm hover:text-charcoal transition-colors">
            Read my full story
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Spotify section ────────────────────────────────── -->
  <section class="py-16 lg:py-20 bg-navy">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="reveal">
        <p class="text-xs font-medium text-sage-light uppercase tracking-widest mb-3">Listen</p>
        <h2 class="font-heading text-2xl lg:text-3xl font-semibold text-cream mb-2">
          Listen to the rhythm
        </h2>
        <p class="text-cream/55 mb-7 max-w-sm mx-auto">
          Get a feel for the vibe — press play.
        </p>
        <SpotifyEmbed />
      </div>
    </div>
  </section>

  <!-- ── Testimonials ───────────────────────────────────── -->
  <section class="py-20 lg:py-28 bg-sage-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">What people say</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">
          Stories of rhythm in action
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {testimonials.map((t, i) => (
          <div class:list={['reveal', `reveal-delay-${i + 1}`]}>
            <TestimonialCard {...t} />
          </div>
        ))}
      </div>

      <div class="text-center mt-10 reveal">
        <a href="/testimonials" class="inline-flex items-center gap-2 text-forest font-medium text-sm hover:text-charcoal transition-colors">
          Read all testimonials
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Contact CTA ────────────────────────────────────── -->
  <section class="py-20 lg:py-28 bg-linen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div class="reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Ready to begin?</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">
            Let's find the right programme for your group
          </h2>
          <p class="text-charcoal/65 leading-relaxed mb-6">
            Whether you know exactly what you need or you're just curious, I'd love to chat. Tell me about your group and I'll come back with ideas tailored to you.
          </p>
          <ul class="space-y-3">
            {[
              'Free initial consultation',
              'Tailored to your group size and needs',
              'Serving Auckland North Shore and surrounds',
            ].map(item => (
              <li class="flex items-center gap-3 text-sm text-charcoal/70">
                <svg class="w-5 h-5 text-sage-dark shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="reveal reveal-delay-2 bg-cream rounded-3xl p-8 border border-linen shadow-sm">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ────────────────────────────────────────────────── */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
    isolation: isolate;
  }

  /* ── Photo layer ─────────────────────────────────────────── */
  .hero-photo {
    position: absolute;
    inset: -2% -2% -2% -2%;
    background-image: url('/images/group.jpg');
    background-size: cover;
    background-position: center 35%;
    z-index: 0;
    animation: hero-zoom 18s ease-out 0.2s both;
    will-change: transform;
  }

  @keyframes hero-zoom {
    from { transform: scale(1.08); }
    to   { transform: scale(1.0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-photo { animation: none; transform: scale(1.0); }
  }

  /* Amber/clay overlay — ties photo's golden light to brand palette */
  .hero-photo::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(
      140deg,
      rgba(196, 168, 130, 0.38) 0%,
      rgba(196, 168, 130, 0.18) 45%,
      rgba(122, 171, 126, 0.12) 100%
    );
  }

  /* Right-edge darkening for depth */
  .hero-photo::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(
      to right,
      transparent 30%,
      rgba(46, 49, 65, 0.3) 100%
    );
  }

  /* ── Charcoal panel ──────────────────────────────────────── */
  .hero-panel {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 58%;
    background: #2E3141;
    clip-path: polygon(0 0, 100% 0, 85% 100%, 0 100%);
    z-index: 1;
  }

  /* Noise texture — stops panel feeling flat */
  .hero-panel::before {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  /* Diagonal edge softener — amber glow blurs the parallelogram cut */
  .hero-panel::after {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 20%;
    background: linear-gradient(to right, transparent, rgba(196, 168, 130, 0.06));
    pointer-events: none;
  }

  /* ── Content (sibling of panel, floats above it) ─────────── */
  .hero-inner {
    position: relative;
    height: 100%;
    z-index: 2;
    max-width: 80rem;
    margin: 0 auto;
    padding: 6.5rem 3.5rem 7rem;
    display: flex;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-inner { padding: 6rem 3.5rem 8rem; }
  }

  .hero-content {
    max-width: 52%;
    width: 100%;
    animation: hero-fade-in 1s ease-out 0.3s both;
  }

  @keyframes hero-fade-in {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-content { animation: none; }
  }

  /* ── Pill ────────────────────────────────────────────────── */
  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.45rem 0.95rem 0.45rem 0.85rem;
    background-color: rgba(122, 171, 126, 0.14);
    border: 1px solid rgba(122, 171, 126, 0.28);
    border-radius: 9999px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.015em;
    color: rgba(122, 171, 126, 0.95);
    margin: 0 0 1.75rem;
  }

  .hero-pill-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background-color: #7AAB7E;
    box-shadow: 0 0 0 0 rgba(122, 171, 126, 0.7);
    animation: hero-pulse 2.4s ease-in-out infinite;
  }

  @keyframes hero-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(122, 171, 126, 0.55); }
    50%      { box-shadow: 0 0 0 6px rgba(122, 171, 126, 0.0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-pill-dot { animation: none; }
  }

  /* ── Heading ─────────────────────────────────────────────── */
  .display-heading {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(3.5rem, 5.5vw, 5.25rem);
    font-variation-settings: 'opsz' 144, 'wght' 700;
    line-height: 0.9;
    color: #F5F0E8;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
    text-wrap: balance;
  }

  .display-accent {
    display: block;
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'wght' 300, 'SOFT' 50;
    color: #C4A882;
    margin-top: 0.08em;
  }

  /* ── Green rule (handcrafted accent) ─────────────────────── */
  .hero-rule {
    width: 2.25rem;
    height: 2px;
    background: #4A7C59;
    border-radius: 1px;
    margin: 0 0 1.25rem;
  }

  /* ── Sub-text ────────────────────────────────────────────── */
  .sub-head {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: rgba(245, 240, 232, 0.72);
    max-width: 28rem;
    margin: 0 0 2.25rem;
    text-wrap: pretty;
  }

  /* ── CTAs ────────────────────────────────────────────────── */
  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .cta-fill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.95rem 1.75rem;
    background-color: #4A7C59;
    color: #F5F0E8;
    border-radius: 9999px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    box-shadow: 0 4px 18px rgba(74, 124, 89, 0.38);
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-fill:hover {
    background-color: #3A5E48;
    transform: translateY(-1px);
    box-shadow: 0 6px 22px rgba(74, 124, 89, 0.45);
  }

  .cta-fill:hover .cta-arrow { transform: translateX(3px); }
  .cta-fill:active {
    transform: translateY(0);
    box-shadow: 0 4px 18px rgba(74, 124, 89, 0.38);
  }

  .cta-arrow {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s ease;
  }

  .cta-outline {
    display: inline-flex;
    align-items: center;
    padding: 0.95rem 1.75rem;
    border: 1.5px solid rgba(245, 240, 232, 0.4);
    color: #F5F0E8;
    border-radius: 9999px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .cta-outline:hover {
    border-color: rgba(245, 240, 232, 0.75);
    background-color: rgba(245, 240, 232, 0.08);
  }

