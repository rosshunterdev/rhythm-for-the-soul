<script>
  // Homepage only: keep nav transparent until scrolled 80px into the page,
  // overriding the default 20px threshold set in Header.astro. Because page
  // scripts run after layout scripts, this listener fires second on each
  // scroll event and reliably wins the classList.toggle race.
  const header = document.getElementById('site-header');
  if (header) {
    const setNavState = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 80);
    };
    window.addEventListener('scroll', setNavState, { passive: true });
    setNavState(); // correct state on initial load / page restore
  }

  // Orbital: rAF-driven bidirectional spin
  // scroll down = clockwise, scroll up = counterclockwise, idle = slow clockwise
  ;(function () {
    const orbital = document.querySelector('.orbital') as HTMLElement | null;
    if (!orbital || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const BASE_VEL  = 0.04;   // deg/frame at idle (~80s per rotation at 60fps)
    const MAX_VEL   = 2;      // deg/frame cap at peak scroll speed
    const LERP      = 0.025;  // easing factor: lower = heavier, more resistant feel

    let angle          = 0;
    let currentVel     = BASE_VEL;
    let targetVel      = BASE_VEL;
    let lastScrollY    = window.scrollY;
    let lastScrollTime = performance.now();
    let resetTimer: ReturnType<typeof setTimeout> | undefined;

    let rafId: number | undefined;
    function tick() {
      currentVel += (targetVel - currentVel) * LERP;
      angle = ((angle + currentVel) % 360 + 360) % 360;
      orbital!.style.transform = `rotate(${angle}deg)`;
      rafId = requestAnimationFrame(tick);
    }
    rafId = requestAnimationFrame(tick);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        cancelAnimationFrame(rafId!);
        rafId = undefined;
      } else if (!rafId) {
        rafId = requestAnimationFrame(tick);
      }
    });

    window.addEventListener('scroll', () => {
      const now  = performance.now();
      const dt   = now - lastScrollTime || 1;
      const dy   = window.scrollY - lastScrollY;          // signed: + down, - up
      if (dy === 0) return;
      const dir  = dy >= 0 ? 1 : -1;
      const mag  = Math.abs(dy) / dt;                     // px/ms magnitude

      targetVel = dir * Math.min(MAX_VEL, BASE_VEL + mag * 0.7);  // 0.7 scales px/ms to deg/frame

      lastScrollY    = window.scrollY;
      lastScrollTime = now;

      clearTimeout(resetTimer);
      resetTimer = setTimeout(() => { targetVel = BASE_VEL; }, 600);
    }, { passive: true });
  })();
</script>

