---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Rhythm for Everyone"
  description="Rhythm for the Soul — drumming workshops, music therapy, and live entertainment on Auckland's North Shore. Led by Julian 'Chewy', connecting communities through the power of rhythm."
>

  <!-- ── Hero ───────────────────────────────────────────── -->
  <section class="hero" aria-label="Introduction">

    <!-- Photo layer: full-bleed, amber overlay via ::before/::after -->
    <div class="hero-photo" aria-hidden="true"></div>

    <!-- Charcoal panel: diagonal clip-path, sibling of content -->
    <div class="hero-panel" aria-hidden="true"></div>

    <!-- Content: z-index above panel, max-width keeps text clear of diagonal -->
    <div class="hero-inner">
      <div class="hero-content">

        <p class="hero-location">Auckland &amp; North Shore</p>

        <h1 class="display-heading">
          Rhythm
          <em class="display-accent">for everyone</em>
        </h1>

        <div class="hero-rule" aria-hidden="true"></div>

        <p class="sub-head">
          Drumming workshops, music therapy, laughter yoga and fire shows.
          Serving schools, rest homes, disability services and corporate events.
        </p>

        <div class="ctas">
          <a href="/drumbeat" class="cta-fill">
            Explore Programmes
          </a>
          <a href="/contact" class="cta-outline">Get in Touch</a>
        </div>

        <p class="hero-attribution">
          Led by <span class="hero-attribution-name">Julian &ldquo;Chewy&rdquo;</span>
          <span class="hero-attribution-sep" aria-hidden="true">·</span>
          <span class="hero-attribution-loc">X+ years on the North Shore</span>
        </p>

      </div>
    </div>

  </section>

  <!-- ── In action ──────────────────────────────────────── -->
  <section class="video-reel" aria-label="Watch us in action">
    <svg
      class="orbital"
      viewBox="0 0 400 400"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      focusable="false"
    >
      <!-- Rings: radii 60, 100, 145, 190 -->
      <circle cx="200" cy="200" r="60"  fill="none" stroke="#C4A882" stroke-width="1.2"/>
      <circle cx="200" cy="200" r="100" fill="none" stroke="#C4A882" stroke-width="1.2"/>
      <circle cx="200" cy="200" r="145" fill="none" stroke="#C4A882" stroke-width="1.5"/>
      <circle cx="200" cy="200" r="190" fill="none" stroke="#C4A882" stroke-width="2.5"/>

      <!-- Center dot -->
      <circle cx="200" cy="200" r="7" fill="#C4A882"/>

      <!-- Ring 1 dots (r=60): θ=-90°, θ=30° -->
      <circle cx="200" cy="140" r="4.5" fill="#C4A882"/>
      <circle cx="252" cy="230" r="4"   fill="#C4A882"/>

      <!-- Ring 2 dots (r=100): θ=-90°, θ=150°, θ=45° -->
      <circle cx="200" cy="100" r="5"   fill="#C4A882"/>
      <circle cx="113" cy="250" r="4.5" fill="#C4A882"/>
      <circle cx="271" cy="271" r="4"   fill="#C4A882"/>

      <!-- Ring 3 dots (r=145): θ=-60°, θ=10°, θ=120°, θ=190° -->
      <circle cx="273" cy="74"  r="5"   fill="#C4A882"/>
      <circle cx="343" cy="225" r="4.5" fill="#C4A882"/>
      <circle cx="128" cy="326" r="4.5" fill="#C4A882"/>
      <circle cx="57"  cy="175" r="4"   fill="#C4A882"/>

      <!-- Ring 4 dots (r=190): 8 evenly spaced at 0°, 45°, 90°, 135°, 180°, 225°, 270°, 315° -->
      <circle cx="390" cy="200" r="5.5" fill="#C4A882"/>
      <circle cx="334" cy="334" r="5"   fill="#C4A882"/>
      <circle cx="200" cy="390" r="5.5" fill="#C4A882"/>
      <circle cx="66"  cy="334" r="5"   fill="#C4A882"/>
      <circle cx="10"  cy="200" r="5.5" fill="#C4A882"/>
      <circle cx="66"  cy="66"  r="5"   fill="#C4A882"/>
      <circle cx="200" cy="10"  r="5.5" fill="#C4A882"/>
      <circle cx="334" cy="66"  r="5"   fill="#C4A882"/>
    </svg>
    <div class="video-reel-inner">
      <div class="video-reel-intro reveal">
        <p class="video-reel-eyebrow">Watch</p>
        <h2 class="video-reel-heading">Rhythm in action</h2>
        <p class="video-reel-sub">[Placeholder: 1-2 sentences describing what viewers will see in the video and why it's worth watching]</p>
      </div>
      <div class="video-reel-wrap reveal reveal-delay-1">
        <video
          class="video-reel-player"
          src="/RFTS%20music%20video.mp4"
          poster="/images/video-screenshot.png"
          controls
          preload="metadata"
          playsinline
        >
          Your browser does not support the video tag.
        </video>
      </div><!-- /.video-reel-wrap -->

      <figure class="video-quote reveal reveal-delay-2">
        <blockquote class="video-quote-text">
          &ldquo;Lorem ipsum dolor sit amet, consectetur adipiscing elit.&rdquo;
        </blockquote>
        <figcaption class="video-quote-attr">
          Lorem Ipsum &middot; Placeholder, Organisation Name
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- ── About Chewy ────────────────────────────────────── -->
  <section class="meet-chewy" id="meet-chewy" aria-label="About Julian Chewy">

    <!-- Photo column -->
    <div class="meet-chewy-photo" aria-hidden="true"></div>

    <!-- Content column -->
    <div class="meet-chewy-content">
      <div class="meet-chewy-inner">

        <p class="meet-chewy-eyebrow reveal">Meet... (your specialist/facilitator)</p>

        <h2 class="meet-chewy-heading reveal reveal-delay-1">
          Julian
          <em class="meet-chewy-accent">&ldquo;Chewy&rdquo;</em>
        </h2>

        <div class="meet-chewy-rule reveal reveal-delay-1" aria-hidden="true"></div>

        <p class="meet-chewy-bio reveal reveal-delay-2">
          Step into the vibrant world of Chewy, a musical maestro with an insatiable passion for all things sonic, especially the rich tapestry of world music.
        </p>

        <ul class="meet-chewy-creds reveal reveal-delay-2" aria-label="Credentials">
          <li>Music therapist</li>
          <li>15+ years of experience</LI>
          <li>Performed in festivals throughout the globe</li>
        </ul>

        <a href="/about" class="meet-chewy-cta reveal reveal-delay-3">
          Read the full story
        </a>

      </div>
    </div>

  </section>

  <!-- ── DRUMBEAT Feature ───────────────────────────────── -->
  <section class="drumbeat-feature" aria-label="Featured Programme">
    <div class="drumbeat-inner">
      <div class="drumbeat-card reveal">

        <!-- Content (left) — placeholder until featured programme is confirmed -->
        <div class="drumbeat-content">

          <p class="drumbeat-badge">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
            Programme Spotlight
          </p>

          <h2 class="drumbeat-heading">To be confirmed</h2>
          <div class="drumbeat-rule" aria-hidden="true"></div>

          <p class="drumbeat-desc">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Lorem ipsum dolor sit amet, consectetur adipiscing elit.
          </p>

        </div>

        <!-- Photo (right) -->
        <div class="drumbeat-photo" aria-hidden="true"></div>

      </div>
    </div>
  </section>

  <!-- ── Services ──────────────────────────────────────── -->
  <section class="services" aria-label="Services by category">
    <div class="services-inner">

      <div class="services-header reveal">
        <p class="services-eyebrow">Every stage of life</p>
        <h2 class="services-heading">
          Find the right
          <em class="services-accent">programme for you</em>
        </h2>
      </div>

      <div class="services-grid">

        <a href="/schools" class="service-tile reveal reveal-delay-1">
          <div class="tile-photo-wrap">
            <div class="tile-photo" style="background-image: url('/images/drum-school-kids.jpg')"></div>
          </div>
          <div class="tile-content">
            <p class="tile-sub">Schools · Early Childhood · Rest Homes · Disability</p>
            <h3 class="tile-name">Community and Education</h3>
          </div>
        </a>

        <a href="/corporate" class="service-tile reveal reveal-delay-2">
          <div class="tile-photo-wrap">
            <div class="tile-photo" style="background-image: url('/images/fire-breathing.png'); background-position: center 30%"></div>
          </div>
          <div class="tile-content">
            <p class="tile-sub">Corporate · School Holidays · Birthdays · Fire Shows</p>
            <h3 class="tile-name">Events and Entertainment</h3>
          </div>
        </a>

        <a href="/sound-journeys" class="service-tile reveal reveal-delay-3">
          <div class="tile-photo-wrap">
            <div class="tile-photo" style="background-image: url('/images/yoga-laugh.jpeg'); background-position: center top"></div>
          </div>
          <div class="tile-content">
            <p class="tile-sub">Sound Journeys · Laughter Yoga</p>
            <h3 class="tile-name">Wellness and Journeys</h3>
          </div>
        </a>

        <a href="/teacher-training" class="service-tile reveal reveal-delay-1">
          <div class="tile-photo-wrap">
            <div class="tile-photo" style="background-image: url('/images/flute.jpg'); background-position: center 20%"></div>
          </div>
          <div class="tile-content">
            <p class="tile-sub">Teacher Training · One-on-one Lessons</p>
            <h3 class="tile-name">Training and Lessons</h3>
          </div>
        </a>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ────────────────────────────────────────────────── */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
    z-index: 1;
    isolation: isolate;
  }

  /* ── Photo layer ─────────────────────────────────────────── */
  .hero-photo {
    position: absolute;
    inset: -2% -2% -2% -2%;
    background-image: url('/images/group.jpg');
    background-size: cover;
    background-position: center 65%;
    transform: scaleX(-1);
    z-index: 0;
    animation: hero-zoom 18s ease-out 0.2s both;
    will-change: transform;
  }

  @keyframes hero-zoom {
    from { transform: scaleX(-1) scale(1.08); }
    to   { transform: scaleX(-1) scale(1.0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-photo { animation: none; transform: scaleX(-1) scale(1.0); }
  }

  /* Amber/clay overlay */
  .hero-photo::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(
      140deg,
      rgba(196, 168, 130, 0.38) 0%,
      rgba(196, 168, 130, 0.18) 45%,
      rgba(122, 171, 126, 0.12) 100%
    );
  }

  /* Right-edge darkening for depth */
  .hero-photo::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(
      to right,
      transparent 30%,
      rgba(46, 49, 65, 0.3) 100%
    );
  }

  /* ── Charcoal panel ──────────────────────────────────────── */
  .hero-panel {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 30%;
    background: #2E3141;
    z-index: 1;
  }

  /* Noise texture */
  .hero-panel::before {
    content: '';
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  /* Soft right-edge fade to ease the hard vertical cut */
  .hero-panel::after {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 25%;
    background: linear-gradient(to right, transparent, rgba(46, 49, 65, 0.85));
    pointer-events: none;
  }

  /* ── Content (sibling of panel, floats above it) ─────────── */
  /* max-width: 30% matches the panel width so justify-content: flex-end
     pushes the content block to the right edge of the charcoal panel */
  .hero-inner {
    position: relative;
    height: 100%;
    max-width: 30%;
    z-index: 2;
    padding: 6.5rem 2rem 7rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero-inner { padding: 6rem 2.5rem 8rem 2rem; }
  }

  .hero-content {
    max-width: 22rem;
    width: 100%;
    animation: hero-fade-in 1s ease-out 0.3s both;
  }

  @keyframes hero-fade-in {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-content { animation: none; }
  }

  /* ── Location label ──────────────────────────────────────── */
  .hero-location {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.45);
    margin: 0 0 1.5rem;
  }

  /* ── Heading ─────────────────────────────────────────────── */
  .display-heading {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(3.5rem, 5.5vw, 5.25rem);
    font-variation-settings: 'opsz' 144, 'wght' 700;
    line-height: 0.9;
    color: #F5F0E8;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
    text-wrap: balance;
  }

  .display-accent {
    display: block;
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'wght' 300, 'SOFT' 50;
    color: #C4A882;
    margin-top: 0.08em;
  }

  /* ── Green rule (handcrafted accent) ─────────────────────── */
  .hero-rule {
    width: 2.25rem;
    height: 2px;
    background: #4A7C59;
    border-radius: 1px;
    margin: 0 0 1.25rem;
  }

  /* ── Sub-text ────────────────────────────────────────────── */
  .sub-head {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: rgba(245, 240, 232, 0.72);
    max-width: 28rem;
    margin: 0 0 2.25rem;
    text-wrap: pretty;
  }

  /* ── CTAs ────────────────────────────────────────────────── */
  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .cta-fill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.95rem 1.75rem;
    background-color: #4A7C59;
    color: #F5F0E8;
    border-radius: 9999px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    box-shadow: 0 4px 18px rgba(74, 124, 89, 0.38);
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-fill:hover {
    background-color: #3A5E48;
    transform: translateY(-1px);
    box-shadow: 0 6px 22px rgba(74, 124, 89, 0.45);
  }

  .cta-fill:hover .cta-arrow { transform: translateX(3px); }
  .cta-fill:active {
    transform: translateY(0);
    box-shadow: 0 4px 18px rgba(74, 124, 89, 0.38);
  }

  .cta-arrow {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s ease;
  }

  .cta-outline {
    display: inline-flex;
    align-items: center;
    padding: 0.95rem 1.75rem;
    border: 1.5px solid rgba(245, 240, 232, 0.4);
    color: #F5F0E8;
    border-radius: 9999px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .cta-outline:hover {
    border-color: rgba(245, 240, 232, 0.75);
    background-color: rgba(245, 240, 232, 0.08);
  }

  /* ── Attribution ─────────────────────────────────────────── */
  .hero-attribution {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.775rem;
    color: rgba(245, 240, 232, 0.42);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .hero-attribution-name {
    color: rgba(245, 240, 232, 0.82);
    font-weight: 600;
  }

  .hero-attribution-sep {
    margin: 0 0.5rem;
    color: rgba(245, 240, 232, 0.25);
  }

  .hero-attribution-loc { white-space: nowrap; }

  /* ── Mobile (< 768px) ────────────────────────────────────── */
  @media (max-width: 767px) {
    .hero {
      height: auto;
      min-height: 0;
    }

    .hero-photo {
      position: relative;
      inset: auto;
      height: 45svh;
      min-height: 220px;
      animation: none;
    }

    .hero-photo::after {
      background: linear-gradient(
        to bottom,
        transparent 40%,
        #2E3141 100%
      );
    }

    .hero-panel { display: none; }

    .hero-inner {
      position: relative;
      height: auto;
      max-width: 100%;
      background: #2E3141;
      padding: 2.5rem 1.25rem 3rem;
      align-items: flex-start;
      justify-content: flex-start;
    }

    .hero-content { max-width: 100%; }

    .sub-head { font-size: 1rem; }

    .ctas { gap: 0.625rem; }

    .cta-fill,
    .cta-outline {
      padding: 0.85rem 1.5rem;
      font-size: 0.875rem;
    }
  }

  /* ── Video reel ─────────────────────────────────────────── */
  .video-reel {
    background: #2E3141;
    padding: 5rem 0 6rem;
    position: relative;
    overflow: hidden;
  }

  .video-reel-inner {
    max-width: 56rem;
    margin: 0 auto;
    padding: 0 1rem;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 640px) {
    .video-reel-inner { padding: 0 1.5rem; }
  }

  @media (min-width: 1024px) {
    .video-reel-inner { padding: 0 2rem; }
  }

  .orbital {
    position: absolute;
    top: 40px;
    left: -80px;
    width: 440px;
    height: 440px;
    opacity: 0.32;
    z-index: 0;
    pointer-events: none;
    /* transform driven by rAF script, not CSS animation */
  }

  @media (prefers-reduced-motion: reduce) {
    .orbital { display: none; }
  }

  .video-reel-intro {
    text-align: center;
    margin-bottom: 2.75rem;
  }

  .video-reel-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-sage);
    margin: 0 0 0.875rem;
  }

  .video-reel-heading {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-variation-settings: 'opsz' 144, 'wght' 600;
    color: var(--color-cream);
    line-height: 1.1;
    margin: 0 0 0.875rem;
  }

  .video-reel-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: rgba(245, 240, 232, 0.52);
    max-width: 30rem;
    margin: 0 auto;
  }

  .video-reel-wrap {
    position: relative;
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(196, 168, 130, 0.18),
      0 0 120px 40px rgba(196, 168, 130, 0.09),
      0 24px 80px rgba(0, 0, 0, 0.50),
      0 6px 24px rgba(0, 0, 0, 0.30);
  }

  .video-reel-player {
    width: 100%;
    display: block;
    background: #1a1c25;
  }

  @media (max-width: 639px) {
    .video-reel { padding: 3.5rem 0 4rem; }
    .video-reel-intro { margin-bottom: 2rem; }
    .video-reel-wrap { border-radius: 0.75rem; }
  }

  /* ── Pull-quote ─────────────────────────────────────────── */
  .video-quote {
    position: relative;
    margin: 2.5rem auto 0;
    padding: 2rem 1rem 0;
    text-align: center;
    max-width: 40rem;
  }

  .video-quote::before {
    content: '\201C';
    font-family: 'Fraunces', Georgia, serif;
    font-size: 8rem;
    line-height: 1;
    color: rgba(196, 168, 130, 0.08);
    position: absolute;
    top: -0.5rem;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
    user-select: none;
  }

  .video-quote-text {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-style: italic;
    font-variation-settings: 'opsz' 72, 'wght' 400;
    color: #C4A882;
    line-height: 1.4;
    margin: 0;
  }

  .video-quote-attr {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    color: rgba(245, 240, 232, 0.45);
    margin-top: 0.75rem;
    letter-spacing: 0.02em;
  }

  /* ── About Chewy ─────────────────────────────────────── */
  .meet-chewy {
    display: grid;
    grid-template-columns: 45% 55%;
    min-height: 88vh;
    position: relative;
  }

  /* Photo column */
  .meet-chewy-photo {
    position: relative;
    overflow: hidden;
    background-image: url('/images/chewy-drum.jpg');
    background-size: cover;
    background-position: center 12%;
  }

  /* Radial overlay: lighter over Chewy, darker at edges to absorb the white wall */
  .meet-chewy-photo::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 58% 72% at 50% 38%,
      rgba(46, 49, 65, 0.28) 0%,
      rgba(46, 49, 65, 0.78) 100%
    );
    pointer-events: none;
  }

  /* Amber warm tint + right-edge fade into content column */
  .meet-chewy-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        150deg,
        rgba(196, 168, 130, 0.32) 0%,
        rgba(196, 168, 130, 0.06) 65%,
