<script>
  // Homepage only: keep nav transparent until scrolled 80px into the page,
  // overriding the default 20px threshold set in Header.astro. Because page
  // scripts run after layout scripts, this listener fires second on each
  // scroll event and reliably wins the classList.toggle race.
  const header = document.getElementById('site-header');
  if (header) {
    const setNavState = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 80);
    };
    window.addEventListener('scroll', setNavState, { passive: true });
    setNavState(); // correct state on initial load / page restore
  }
</script>

