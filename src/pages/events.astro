---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';

const eventTypes = [
  {
    title: 'Birthday drumming parties',
    eyebrow: 'Celebrate',
    description: 'An unforgettable birthday experience for kids and adults alike. Chewy leads an interactive drumming party — high energy, inclusive, and guaranteed to have everyone on their feet.',
    details: ['Ages 5 to adult', 'Suitable for 10–50+ guests', 'All equipment provided', '60–90 minutes'],
    service: 'birthday-party',
  },
  {
    title: 'Sound journeys',
    eyebrow: 'Heal & restore',
    description: 'Lie back, close your eyes, and let the sound wash over you. A deeply immersive experience using djembe, handpan, didgeridoo, native flutes, and other resonant instruments to guide a journey of relaxation and renewal.',
    details: ['For groups or individual bookings', '60–90 minutes', 'Suitable for all ages', 'Mats and props provided'],
    service: 'sound-journey',
  },
  {
    title: 'Fire shows & performance',
    eyebrow: 'Be amazed',
    description: 'Dramatic, mesmerising fire twirling performances that elevate any event into something truly memorable. Available as pure performance or as a workshop where participants learn the basics.',
    details: ['Evening events recommended', 'Indoor/outdoor depending on setup', 'Performance + optional workshop', 'Safety equipment and insurance covered'],
    service: 'fire-show',
  },
  {
    title: 'Laughter yoga & rhythm',
    eyebrow: 'Laugh & connect',
    description: 'A joyful fusion of laughter yoga and group drumming — scientifically shown to reduce cortisol, boost immunity, and create instant human connection. Surprisingly profound, definitely hilarious.',
    details: ['For groups of 8–50', '45–90 minutes', 'No prior experience needed', 'Suitable for all fitness levels'],
    service: 'laughter-yoga',
  },
  {
    title: '1-on-1 drumming sessions',
    eyebrow: 'Personal journey',
    description: 'Private, tailored sessions for individuals seeking a personal rhythm practice, music therapy support, learning a specific instrument, or simply space to explore sound without a group setting.',
    details: ['By appointment', '60–90 minutes per session', 'Available at your location or Chewy\'s studio', 'Ongoing or one-off sessions'],
    service: 'one-on-one',
  },
];
---

<BaseLayout
  title="Events — Parties, Fire Shows, Sound Journeys & More"
  description="Event entertainment and individual sessions from Rhythm for the Soul — birthday drumming parties, fire shows, sound journeys, laughter yoga, and 1-on-1 sessions. Auckland's North Shore."
>

  <Hero
    eyebrow="Events & individual sessions"
    title="Rhythm for every occasion"
    subtitle="From birthday beats to healing sound journeys — bring something extraordinary to your next event"
    description="Whether you're planning a celebration, seeking a personal wellness experience, or want to add something truly memorable to your event — there's a Rhythm for the Soul experience for you."
    ctaPrimary={{ label: 'Enquire About an Event', href: '#contact' }}
    ctaSecondary={{ label: 'See all programmes', href: '/' }}
  />

  <!-- Event types -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">What's on offer</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">Five ways to experience rhythm</h2>
        <p class="text-charcoal/60 mt-3 max-w-xl mx-auto">Each experience is uniquely designed — from high-energy celebrations to deeply restoring sound journeys.</p>
      </div>

      <div class="space-y-8 lg:space-y-12">
        {eventTypes.map((event, i) => (
          <div class:list={['reveal', `reveal-delay-${(i % 3) + 1}`, 'grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center', i % 2 !== 0 ? 'lg:flex-row-reverse' : '']}>
            <!-- Image placeholder -->
            <div class:list={[i % 2 !== 0 ? 'lg:order-2' : '']}>
              <div class="rounded-3xl bg-linen aspect-[16/9] flex items-center justify-center relative overflow-hidden">
                <svg class="w-16 h-16 text-sage/25" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="0.75">
                  <circle cx="24" cy="24" r="22"/><circle cx="24" cy="24" r="14"/>
                  <circle cx="24" cy="24" r="6" fill="currentColor" opacity="0.4"/>
                </svg>
                <p class="absolute bottom-3 text-stone/40 text-xs">Photo coming soon</p>
              </div>
            </div>

            <!-- Text -->
            <div class:list={[i % 2 !== 0 ? 'lg:order-1' : '']}>
              <p class="text-xs font-medium text-gold uppercase tracking-widest mb-3">{event.eyebrow}</p>
              <h2 class="font-heading text-2xl lg:text-3xl font-semibold text-charcoal mb-4">{event.title}</h2>
              <p class="text-charcoal/65 leading-relaxed mb-5">{event.description}</p>
              <ul class="space-y-2 mb-6">
                {event.details.map(detail => (
                  <li class="flex items-center gap-2 text-sm text-charcoal/60">
                    <svg class="w-4 h-4 text-sage-dark shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {detail}
                  </li>
                ))}
              </ul>
              <a
                href={`/contact?service=${event.service}`}
                class="inline-flex items-center gap-2 px-6 py-3 bg-gold text-cream rounded-full font-medium text-sm hover:bg-gold-dark transition-colors shadow-sm"
              >
                Enquire about this
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Highlight: Sound journeys -->
  <section class="py-16 lg:py-20 bg-charcoal">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <p class="text-xs font-medium text-sage-light uppercase tracking-widest mb-3">Featured experience</p>
      <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-cream mb-5">
        Sound journeys — the deepest rest you'll find
      </h2>
      <p class="text-cream/65 leading-relaxed mb-8 max-w-2xl mx-auto">
        Imagine an hour where you do absolutely nothing but receive. No agenda, no performance, no expectations — just wave upon wave of resonant sound flowing through you, carried by handpan, didgeridoo, native flute, and the resonant hum of the djembe.
      </p>
      <p class="text-cream/65 leading-relaxed mb-8 max-w-2xl mx-auto">
        Participants often describe the experience as the most rested they've felt in years. Sound journeys are available for private bookings, wellness events, yoga studios, and corporate wellness programmes.
      </p>
      <a href="/contact?service=sound-journey" class="inline-flex items-center gap-2 px-7 py-3.5 bg-gold text-cream rounded-full font-medium text-sm hover:bg-gold-dark transition-colors">
        Book a sound journey
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="py-20 lg:py-28 bg-linen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div class="reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Make an enquiry</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">Tell me about your event</h2>
          <p class="text-charcoal/65 leading-relaxed mb-6">Not sure which experience is right for you? Describe what you're looking for and I'll help you find the perfect fit.</p>
          <ul class="space-y-3">
            {['Flexible dates and locations', 'All equipment and logistics handled', 'Custom packages available', 'Auckland North Shore and surrounds'].map(item => (
              <li class="flex items-center gap-3 text-sm text-charcoal/70">
                <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal reveal-delay-2 bg-cream rounded-3xl p-8 border border-linen shadow-sm">
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-6">Enquire about an event</h3>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
