---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
import TestimonialCard from '../components/TestimonialCard.astro';

const benefits = [
  { title: 'Joy & mood lifting', description: 'Rhythm is immediately mood-elevating. Residents who arrive subdued often leave animated, smiling, and carrying the energy of the session with them.' },
  { title: 'Cognitive stimulation', description: 'Rhythmic patterns engage memory, attention, and sequential processing. Even residents with moderate to advanced dementia often respond meaningfully — music accesses pathways that other activities cannot.' },
  { title: 'Social connection', description: 'The drum circle creates a shared activity that encourages conversation, laughter, and connection between residents who might otherwise stay in their rooms.' },
  { title: 'Memory & reminiscence', description: 'Music reaches deep into long-term memory. Familiar songs and rhythms can spark vivid recollections, prompting meaningful conversations about the past.' },
  { title: 'Physical engagement', description: 'Gentle drumming, movement, and song promote upper-body coordination and the physiological benefits of rhythmic activity — all achievable from a chair or wheelchair, at whatever level the resident can manage.' },
  { title: 'Sense of accomplishment', description: 'Contributing meaningfully to a group musical experience — regardless of ability — restores a sense of agency and pride that institutional care can sometimes diminish.' },
];

const whatToExpect = [
  { step: '01', title: 'Warm welcome & introductions', description: 'Sessions are relaxed and conversational from the first moment. Residents are never rushed or pressured to participate in any particular way.' },
  { step: '02', title: 'Familiar music & song', description: 'We weave in songs from the era residents grew up in — a bridge between memory and the present moment.' },
  { step: '03', title: 'Gentle percussion play', description: 'Hand drums, shakers, bells, and rhythm sticks — instruments chosen for accessibility and ease. Adaptive options are available for residents with limited hand strength or mobility, including wheelchair users.' },
  { step: '04', title: 'Group rhythm & improvisation', description: 'Simple group rhythms that everyone can join at their own level — no experience, reading, or ability required.' },
  { step: '05', title: 'Stories & conversation', description: 'The instruments often open doors to stories. Chewy facilitates the conversation as naturally as the music — sessions regularly become joyful, spontaneous gatherings.' },
];
---

<BaseLayout
  title="Rest Homes & Aged Care Sessions"
  description="Music therapy and drumming sessions for rest homes and aged care on Auckland's North Shore. Joyful, gentle experiences that lift mood and build connection."
>

  <Hero
    eyebrow="Aged care & residential"
    title="Bringing rhythm and joy to aged care"
    subtitle="Interactive music sessions that lift mood, spark memories, and give residents something to look forward to"
    description="Drumming, singing, gentle movement, and sensory engagement — delivered by a specialist with 20+ years in disability and aged care. Fully seated, wheelchair-friendly, and adapted to your residents."
    ctaPrimary={{ label: 'Book a Session', href: '#contact' }}
    ctaSecondary={{ label: 'See all programmes', href: '/' }}
  />

  <!-- About -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Why rhythm for older adults?</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">
            Music is the one language that never needs translation
          </h2>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            For many older adults in residential care, the days can feel long and the world can feel far away. Music has a unique power to cut through that distance — activating memory, emotion, and connection in ways that nothing else quite can.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            Sessions blend drumming, singing, gentle movement, and sensory engagement into a one-hour experience designed to be accessible to all levels of ability — including residents with dementia, limited mobility, or sensory impairment. Every session is fully seated and wheelchair-friendly.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            Chewy brings over 20 years of experience facilitating sessions in disability and aged care settings. That depth of experience means he knows how to read a room, adapt in real time, and create moments of genuine joy — even with groups whose engagement can be unpredictable.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-6">
            He works closely with your activities team before each session to understand residents' needs, communication styles, and any clinical considerations — so staff feel confident, not stressed, when he walks through the door.
          </p>
          <div class="flex flex-wrap gap-3">
            <span class="px-3 py-1.5 bg-sage/15 text-sage-dark rounded-full text-xs font-medium">Rest homes</span>
            <span class="px-3 py-1.5 bg-sage/15 text-sage-dark rounded-full text-xs font-medium">Memory care</span>
            <span class="px-3 py-1.5 bg-sage/15 text-sage-dark rounded-full text-xs font-medium">Day programmes</span>
            <span class="px-3 py-1.5 bg-sage/15 text-sage-dark rounded-full text-xs font-medium">Hospital wards</span>
          </div>
        </div>
        <div class="reveal reveal-delay-2">
          <div class="rounded-3xl bg-linen aspect-[4/3] flex items-center justify-center relative overflow-hidden">
            <svg class="w-20 h-20 text-sage/20" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="0.75">
              <circle cx="24" cy="24" r="22"/><circle cx="24" cy="24" r="16"/>
              <circle cx="24" cy="24" r="10"/><circle cx="24" cy="24" r="4" fill="currentColor"/>
            </svg>
            <p class="absolute bottom-4 text-stone/50 text-xs">Session photo coming soon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-20 lg:py-28 bg-linen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Key outcomes</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">What residents gain</h2>
        <p class="text-charcoal/60 mt-3 max-w-xl mx-auto">Observed across hundreds of sessions in residential care settings across Auckland.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {benefits.map((b, i) => (
          <div class:list={['reveal', `reveal-delay-${(i % 3) + 1}`, 'bg-cream rounded-2xl p-6 border border-linen']}>
            <h3 class="font-heading text-lg font-semibold text-charcoal mb-2">{b.title}</h3>
            <p class="text-sm text-charcoal/60 leading-relaxed">{b.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Session structure</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">What to expect</h2>
        <p class="text-charcoal/60 mt-3">Sessions run approximately 60 minutes, fully seated and wheelchair-friendly. All instruments are provided. Participation is always voluntary — residents engage at whatever level feels right for them.</p>
      </div>
      <div class="space-y-6">
        {whatToExpect.map((step, i) => (
          <div class:list={['reveal', `reveal-delay-${i + 1}`, 'flex gap-5 items-start']}>
            <div class="shrink-0 w-12 h-12 rounded-full bg-forest flex items-center justify-center">
              <span class="font-heading text-sm font-semibold text-cream">{step.step}</span>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-charcoal mb-1">{step.title}</h3>
              <p class="text-sm text-charcoal/60 leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16 lg:py-20 bg-linen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
      <TestimonialCard
        quote="The residents absolutely light up when Chewy arrives. Some of our quieter residents become the most enthusiastic participants — rhythm reaches places that words can't. We've seen people with quite advanced dementia engage meaningfully in these sessions in ways that surprise even their families."
        author="Margaret Collins"
        role="Activities Coordinator"
        organization="Bayswater Rest Home"
        featured={true}
      />
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div class="reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Book a session</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">Bring rhythm to your residents</h2>
          <p class="text-charcoal/65 leading-relaxed mb-6">Whether you're looking for a regular weekly session, a one-off special occasion, or a trial visit — I'll work with your activities team to plan a session that's right for your residents. I handle all setup, instruments, and packdown.</p>
          <ul class="space-y-3">
            {['Fully seated and wheelchair-friendly', 'All instruments provided and transported', 'Available for regular weekly or fortnightly sessions', 'Sensitive to dementia and palliative care settings', 'Happy to meet the team and residents before the first session'].map(item => (
              <li class="flex items-center gap-3 text-sm text-charcoal/70">
                <svg class="w-5 h-5 text-forest shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal reveal-delay-2 bg-linen rounded-3xl p-8 border border-linen/80">
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-6">Enquire about rest home sessions</h3>
          <ContactForm preselectedService="Rest Homes" />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
