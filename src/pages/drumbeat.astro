---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
import TestimonialCard from '../components/TestimonialCard.astro';

const benefits = [
  {
    title: 'Emotional regulation',
    description: 'Rhythm provides a powerful, non-verbal outlet for processing emotion — helping young people manage stress, anxiety, and frustration.',
    icon: '♡',
  },
  {
    title: 'Resilience & self-worth',
    description: 'Every participant finds their beat. Success in the group circle builds real confidence that transfers into daily life.',
    icon: '◎',
  },
  {
    title: 'Social connection',
    description: "Drumming together creates belonging. The circle is a natural equaliser — there's no front row, no hierarchy.",
    icon: '◉',
  },
  {
    title: 'Improved focus & attendance',
    description: 'Schools report measurable improvements in engagement and school attendance among DRUMBEAT participants.',
    icon: '▲',
  },
  {
    title: 'Cultural identity',
    description: 'World percussion traditions connect participants to a global heritage of rhythm, storytelling, and community.',
    icon: '✦',
  },
  {
    title: 'Communication skills',
    description: 'Listening, responding, leading, following — the call-and-response of drumming mirrors the foundations of healthy communication.',
    icon: '◈',
  },
];

const whatToExpect = [
  {
    step: '01',
    title: 'Welcome circle',
    description: 'We open with a brief grounding ritual — slow, shared breathing, setting intention, and establishing group agreements. Everyone is welcomed exactly as they are.',
  },
  {
    step: '02',
    title: 'Body percussion warm-up',
    description: 'Before touching a drum, we use clapping, stomping, and vocalising to wake up the body and synchronise the group.',
  },
  {
    step: '03',
    title: 'Instrument introduction',
    description: "Participants are introduced to djembes and other hand percussion instruments. We explore textures, tones, and the joy of making sound before the structure begins.",
  },
  {
    step: '04',
    title: 'Guided rhythm exercises',
    description: 'Call-and-response patterns, group improvisation, and structured rhythms drawn from West African, Latin, and Indigenous drumming traditions.',
  },
  {
    step: '05',
    title: 'Reflection & close',
    description: 'A space for optional sharing — what came up, what shifted, what feels different. We close as we opened: in a circle, together.',
  },
];
---

<BaseLayout
  title="DRUMBEAT Programme"
  description="DRUMBEAT — an evidence-based music therapy programme using hand drumming to build resilience, self-regulation, and social connection in young people. Auckland's North Shore."
>

  <!-- Hero -->
  <Hero
    eyebrow="Evidence-based youth programme"
    title="DRUMBEAT"
    subtitle="Discovering Rhythm, Unity, Music, Brotherhood, Expression, Awareness & Transformation"
    description="An internationally recognised group drumming programme designed to support the social-emotional wellbeing of young people through the power of rhythm."
    ctaPrimary={{ label: 'Book a DRUMBEAT Session', href: '#contact' }}
    ctaSecondary={{ label: 'Learn about other programmes', href: '/#programmes' }}
  />

  <!-- What is DRUMBEAT -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal">
          <p class="text-xs font-medium text-forest uppercase tracking-widest mb-3">About the programme</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">
            More than drumming — a pathway to wellbeing
          </h2>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            DRUMBEAT (Discovering Rhythm, Unity, Music, Brotherhood, Expression, Awareness, and Transformation) is a structured group programme that uses hand drumming as its primary therapeutic medium.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            Developed in Australia and delivered across New Zealand, it's grounded in the evidence that music, rhythm, and group experience together create conditions for real emotional and social growth — especially for young people who struggle to connect through traditional talk-based approaches.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-6">
            DRUMBEAT works because rhythm is universal. It bypasses language and cultural barriers to create an immediate shared experience — something that simply doesn't happen in a classroom or a counselling room.
          </p>
          <div class="flex flex-wrap gap-3">
            <span class="px-3 py-1.5 bg-forest/10 text-forest rounded-full text-xs font-medium">Schools</span>
            <span class="px-3 py-1.5 bg-forest/10 text-forest rounded-full text-xs font-medium">Community groups</span>
            <span class="px-3 py-1.5 bg-forest/10 text-forest rounded-full text-xs font-medium">Youth services</span>
            <span class="px-3 py-1.5 bg-forest/10 text-forest rounded-full text-xs font-medium">At-risk youth</span>
          </div>
        </div>

        <!-- Image placeholder -->
        <div class="reveal reveal-delay-2">
          <div class="rounded-3xl bg-linen aspect-[4/3] flex items-center justify-center relative overflow-hidden">
            <svg class="w-20 h-20 text-forest/20" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="0.75">
              <circle cx="24" cy="24" r="22"/><circle cx="24" cy="24" r="16"/>
              <circle cx="24" cy="24" r="10"/><circle cx="24" cy="24" r="4" fill="currentColor"/>
            </svg>
            <p class="absolute bottom-4 text-stone/50 text-xs text-center">Programme photo coming soon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-20 lg:py-28 bg-linen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Key outcomes</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">
          What DRUMBEAT builds
        </h2>
        <p class="text-charcoal/60 mt-3 max-w-xl mx-auto">
          Outcomes are backed by research and observed by schools, youth workers, and families across New Zealand.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {benefits.map((b, i) => (
          <div class:list={['reveal', `reveal-delay-${(i % 3) + 1}`]}>
            <div class="bg-cream rounded-2xl p-6 border border-linen h-full">
              <div class="w-10 h-10 rounded-xl bg-forest/10 flex items-center justify-center text-forest text-lg mb-4">
                {b.icon}
              </div>
              <h3 class="font-heading text-lg font-semibold text-charcoal mb-2">{b.title}</h3>
              <p class="text-sm text-charcoal/60 leading-relaxed">{b.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12 reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Session structure</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">
            What to expect
          </h2>
          <p class="text-charcoal/60 mt-3">
            Each DRUMBEAT session runs 45–90 minutes and follows a gentle, consistent structure that participants come to find grounding and familiar.
          </p>
        </div>

        <div class="space-y-6">
          {whatToExpect.map((step, i) => (
            <div class:list={['reveal', `reveal-delay-${i + 1}`, 'flex gap-5 items-start']}>
              <div class="shrink-0 w-12 h-12 rounded-full bg-forest flex items-center justify-center">
                <span class="font-heading text-sm font-semibold text-cream">{step.step}</span>
              </div>
              <div>
                <h3 class="font-heading text-lg font-semibold text-charcoal mb-1">{step.title}</h3>
                <p class="text-sm text-charcoal/60 leading-relaxed">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16 lg:py-20 bg-linen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
      <TestimonialCard
        quote="The DRUMBEAT programme has become one of the most powerful tools in our wellbeing toolkit. Students who we'd struggled to reach through traditional pastoral care were showing up, drumming together, and actually talking about how they felt. The transformation wasn't subtle — it was profound."
        author="Kiri Whaanga"
        role="Dean of Students"
        organization="West Auckland Intermediate"
        featured={true}
      />
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div class="reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Take the next step</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">
            Bring DRUMBEAT to your school or group
          </h2>
          <p class="text-charcoal/65 leading-relaxed mb-6">
            DRUMBEAT is available as a standalone workshop series, a term-long programme, or an ongoing wellbeing initiative. Let's talk about what would work best for your group.
          </p>
          <ul class="space-y-3">
            {[
              'Suitable for ages 8–25',
              'Groups of 8–20 participants',
              'Can be delivered at your site',
              'Term-long and single-session options',
            ].map(item => (
              <li class="flex items-center gap-3 text-sm text-charcoal/70">
                <svg class="w-5 h-5 text-forest shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal reveal-delay-2 bg-linen rounded-3xl p-8 border border-linen/80">
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-6">Enquire about DRUMBEAT</h3>
          <ContactForm preselectedService="DRUMBEAT" />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
