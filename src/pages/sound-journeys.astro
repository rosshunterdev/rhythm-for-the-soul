---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sound Journeys"
  description="Meditative sound journey experiences on Auckland's North Shore. Rhythm for the Soul guides groups through immersive rhythm and relaxation sessions."
>
  <div class="flex min-h-screen items-center justify-center px-6" style="padding-top: 7rem; padding-bottom: 4rem;">
    <div class="text-center">
      <p class="mb-5 text-xs font-semibold uppercase text-sage" style="letter-spacing: 0.2em; font-family: 'DM Sans', sans-serif;">Wellness &amp; Journeys</p>
      <h1 class="font-heading text-cream" style="font-size: clamp(3.5rem, 7vw, 6rem); line-height: 1; letter-spacing: -0.02em;">Sound Journeys</h1>
    </div>
  </div>
</BaseLayout>
