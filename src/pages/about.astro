---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';

const instruments = [
  { name: 'Djembe', origin: 'West Africa', description: 'The heartbeat of most sessions — the djembe\'s tones of bass, tone, and slap carry the foundation of rhythm.' },
  { name: 'Handpan', origin: 'Switzerland / Global', description: 'A mysterious, ethereal instrument whose resonance feels like sunlight through water. Central to sound journeys.' },
  { name: 'Didgeridoo', origin: 'Australia', description: 'The low, earth-deep drone of the didgeridoo grounds any space it fills. Profoundly meditative.' },
  { name: 'Native American flute', origin: 'North America', description: 'A voice from the land — hauntingly beautiful, and surprisingly easy to begin playing.' },
  { name: 'Frame drums', origin: 'Global tradition', description: 'From Irish bodhráns to Middle Eastern riq, frame drums connect participants to traditions spanning thousands of years.' },
  { name: 'Ocean drum, singing bowls, and more', origin: 'Various', description: 'A diverse collection of percussion and tonal instruments drawn on for sound journeys and therapeutic work.' },
];

const values = [
  { title: 'Rhythm is a birthright', description: 'Every human being has rhythm — we are born into it. The work is about reconnection, not instruction.' },
  { title: 'Inclusion is non-negotiable', description: 'The drum circle has no hierarchy, no minimum ability, no prerequisites. Every voice contributes to the whole.' },
  { title: 'Presence over performance', description: 'Chewy facilitates experiences, not performances. The goal is never to impress — it\'s to connect.' },
  { title: 'The body knows things the mind doesn\'t', description: 'Rhythm works below the level of language and conscious thought. That\'s where real change often begins.' },
];
---

<BaseLayout
  title="About Chewy"
  description="Meet Julian 'Chewy' — drumming facilitator, music therapist, and performer based on Auckland's North Shore, New Zealand."
>

  <!-- Hero -->
  <section class="bg-charcoal py-20 lg:py-28 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full bg-forest/30 blur-3xl"></div>
      <div class="absolute -bottom-20 -left-20 w-72 h-72 rounded-full bg-sage-dark/20 blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <p class="text-xs font-medium text-sage-light uppercase tracking-widest mb-4">Meet your facilitator</p>
          <h1 class="font-heading text-5xl lg:text-6xl font-semibold text-cream mb-6">
            Hi, I'm Chewy
          </h1>
          <p class="text-xl text-cream/70 font-light leading-relaxed mb-4">
            Drumming facilitator, music therapist, and performer based on Auckland's North Shore.
          </p>
          <p class="text-cream/55 leading-relaxed">
            For over a decade I've been connecting people — young and old, able-bodied and differently abled, corporate teams and quiet individuals — through the universal language of rhythm.
          </p>
        </div>

        <!-- Photo placeholder -->
        <div>
          <div class="rounded-3xl bg-forest/30 aspect-[3/4] flex items-center justify-center relative overflow-hidden max-w-sm mx-auto lg:max-w-none">
            <div class="absolute inset-0 bg-gradient-to-t from-charcoal/40 to-transparent"></div>
            <svg class="w-24 h-24 text-sage/20" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="0.5">
              <circle cx="24" cy="24" r="22"/><circle cx="24" cy="24" r="16"/>
              <circle cx="24" cy="24" r="10"/><circle cx="24" cy="24" r="4" fill="currentColor"/>
            </svg>
            <p class="absolute bottom-4 text-cream/40 text-xs text-center">Photo of Chewy coming soon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-4">My story</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-8">
            The beat that started everything
          </h2>
        </div>
        <div class="space-y-5 text-charcoal/70 leading-relaxed">
          <p class="reveal">
            I didn't grow up thinking I'd spend my life with drums. But somewhere along the way — a workshop here, an encounter with a West African master there — rhythm got into me and I realised I wasn't going to shake it loose. Nor did I want to.
          </p>
          <p class="reveal reveal-delay-1">
            I trained in DRUMBEAT facilitation, immersed myself in music therapy approaches, and spent years learning instruments from traditions around the world — West African djembe, handpan, Australian didgeridoo, Native American flute. Every tradition taught me something different about what music is actually for: not performance, not acclaim, but connection.
          </p>
          <p class="reveal reveal-delay-2">
            My early work was with young people — schools, youth programmes, community groups. I saw what happened when a teenager who'd been written off picked up a drum and found their beat. I saw classrooms transform from collections of individuals into actual communities. I saw kids who hadn't spoken in group settings for months lean forward and start contributing.
          </p>
          <p class="reveal reveal-delay-3">
            Over time, the work expanded — rest homes, disability services, corporate teams, wellness events. What I discovered is that the drum circle works the same way every time, regardless of age or ability: it creates a space where every person is both a contributor and a receiver, simultaneously making the music and being changed by it.
          </p>
          <p class="reveal reveal-delay-4">
            That's what Rhythm for the Soul is about. Not teaching people to play drums — though some do go on to learn. But showing people that rhythm already lives inside them, and giving them a safe, joyful space to let it out.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Watch Chewy in action -->
  <section class="py-16 lg:py-20 bg-linen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-7 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Watch</p>
        <h2 class="font-heading text-2xl lg:text-3xl font-semibold text-charcoal">
          See it for yourself
        </h2>
        <p class="text-charcoal/60 mt-2 text-sm">
          A thousand words about rhythm are worth nothing compared to thirty seconds of watching it happen.
        </p>
      </div>
      <div class="reveal reveal-delay-1">
        <YouTubeEmbed
          videoId="dQw4w9WgXcQ"
          title="Watch Chewy facilitate a drumming session"
          caption="Placeholder — Chewy's own footage coming soon"
        />
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 lg:py-28 bg-linen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">What I believe</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">The principles behind the practice</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {values.map((v, i) => (
          <div class:list={['reveal', `reveal-delay-${i + 1}`, 'bg-cream rounded-2xl p-7 border border-linen']}>
            <h3 class="font-heading text-xl font-semibold text-charcoal mb-3">{v.title}</h3>
            <p class="text-sm text-charcoal/60 leading-relaxed">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Instruments -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">The instruments</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">Tools of the trade</h2>
        <p class="text-charcoal/60 mt-3 max-w-xl mx-auto">
          Each instrument carries its own tradition, its own voice, and its own way of opening something in the people who play it.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {instruments.map((inst, i) => (
          <div class:list={['reveal', `reveal-delay-${(i % 3) + 1}`, 'rounded-2xl bg-linen border border-linen p-6']}>
            <div class="flex items-baseline justify-between mb-3">
              <h3 class="font-heading text-lg font-semibold text-charcoal">{inst.name}</h3>
              <span class="text-xs text-stone">{inst.origin}</span>
            </div>
            <p class="text-sm text-charcoal/60 leading-relaxed">{inst.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16 lg:py-20 bg-linen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
      <TestimonialCard
        quote="Chewy brings a rare combination of genuine musicianship, therapeutic wisdom, and pure human warmth to everything he does. Whether you're a 4-year-old picking up a shaker or a 75-year-old with arthritis reaching for a drum, he makes you feel like you belong in that circle completely."
        author="Dr. Sarah Fleming"
        role="Registered Music Therapist"
        organization="Auckland"
        featured={true}
      />
    </div>
  </section>

  <!-- Qualifications strip -->
  <section class="py-12 lg:py-16 bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center reveal">
        {[
          { label: 'DRUMBEAT', sub: 'Certified facilitator' },
          { label: 'Music Therapy', sub: 'Training & practice' },
          { label: 'Fire Arts', sub: 'Certified instructor' },
        ].map(item => (
          <div class="py-4">
            <p class="font-heading text-lg font-semibold text-cream mb-1">{item.label}</p>
            <p class="text-sm text-cream/45">{item.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div class="reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Work with Chewy</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">Let's make something together</h2>
          <p class="text-charcoal/65 leading-relaxed mb-6">Whether you have a specific programme in mind or you're just curious about what's possible, reach out. I love a good conversation about rhythm.</p>
          <a href="/testimonials" class="inline-flex items-center gap-2 text-forest font-medium text-sm hover:text-charcoal transition-colors">
            Read what others say about working with me
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div class="reveal reveal-delay-2 bg-linen rounded-3xl p-8 border border-linen/80">
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-6">Get in touch</h3>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
