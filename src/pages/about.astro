---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Chewy"
  description="Meet Julian 'Chewy' — drumming facilitator, music therapist, and performer based on Auckland's North Shore, New Zealand."
>
  <div class="flex min-h-screen items-center justify-center px-6" style="padding-top: 7rem; padding-bottom: 4rem;">
    <div class="text-center">
      <p class="mb-5 text-xs font-semibold uppercase text-sage" style="letter-spacing: 0.2em; font-family: 'DM Sans', sans-serif;">Meet your facilitator</p>
      <h1 class="font-heading text-cream" style="font-size: clamp(3.5rem, 7vw, 6rem); line-height: 1; letter-spacing: -0.02em;">About Chewy</h1>
    </div>
  </div>
</BaseLayout>
