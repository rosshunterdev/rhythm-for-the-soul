---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
import TestimonialCard from '../components/TestimonialCard.astro';

const benefits = [
  { title: 'Instant team cohesion', description: 'There\'s no faster way to break down walls between colleagues than making music together. The drum circle creates belonging in minutes, not months.' },
  { title: 'Stress relief that actually works', description: 'Drumming is physically satisfying, rhythmically engaging, and genuinely fun. Participants leave sessions measurably lighter.' },
  { title: 'No hierarchy in the circle', description: 'The CEO and the intern pick up the same instrument. For an hour, everyone is equal — and that shift can unlock conversations and connections that wouldn\'t happen otherwise.' },
  { title: 'Active participation, not passive consumption', description: 'Unlike presentations or passive team-building activities, drumming demands presence. Everyone contributes, everyone is heard.' },
  { title: 'Memorable & unique', description: 'Your team will still be talking about it at the next company event. A drumming session leaves a lasting impression because it\'s genuinely unlike anything most people have done together before.' },
  { title: 'Scalable & flexible', description: 'From a 10-person leadership team to a 200-person company-wide gathering — the drum circle scales without losing its power.' },
];

const whatToExpect = [
  { step: '01', title: 'Energetic welcome', description: 'Chewy arrives with a full kit of hand drums, percussion, and energy. The setup is visually striking — participants know something different is about to happen.' },
  { step: '02', title: 'Ice-breaker rhythms', description: 'Simple, fun rhythm games that get everyone laughing and moving — no experience needed, no wrong answers.' },
  { step: '03', title: 'Group drumming journey', description: 'Building from simple foundations to complex, layered rhythms — the whole team discovers they can make something extraordinary together.' },
  { step: '04', title: 'Leadership challenges', description: 'Optional leadership and improvisation exercises that create space for different voices to lead and different styles to shine.' },
  { step: '05', title: 'Performance finale', description: 'The session culminates with the group performing their rhythm together — a genuine shared achievement that provides a natural, energising high.' },
];

const formats = [
  { title: '60-minute energiser', description: 'Perfect for conference breaks, end-of-day wind-downs, or as part of a wider team event. Fast, fun, and memorable.', duration: '60 min', size: 'Up to 50 people' },
  { title: '2-hour workshop', description: 'Time to go deeper — more skill-building, richer group dynamics, and a stronger sense of shared achievement.', duration: '2 hours', size: 'Up to 80 people' },
  { title: 'Half-day programme', description: 'The full Rhythm for the Soul corporate experience — ideal for off-sites, leadership retreats, and company-wide team days.', duration: '3–4 hours', size: 'Up to 150 people' },
];
---

<BaseLayout
  title="Corporate Team Building"
  description="Corporate team building through rhythm — high-energy, inclusive drumming workshops for workplace teams on Auckland's North Shore. No experience needed."
>

  <Hero
    eyebrow="Corporate & workplace"
    title="Team building that actually beats"
    subtitle="High-energy, inclusive rhythm workshops for teams of all sizes"
    description="Forget the trust falls. A drum circle breaks down hierarchy, builds genuine connection, and leaves your team energised, cohesive, and laughing. No musical experience required."
    ctaPrimary={{ label: 'Book a Corporate Session', href: '#contact' }}
    ctaSecondary={{ label: 'See all programmes', href: '/' }}
  />

  <!-- Intro -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal">
          <p class="text-xs font-medium text-gold uppercase tracking-widest mb-3">Why rhythm at work?</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">
            You don't need music skills to make extraordinary music together
          </h2>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            A drum circle works because it's impossible to phone in. When you're holding a djembe and the group is building a rhythm around you, you're present — completely, physically, joyfully present. That presence is the foundation of real team connection.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            These sessions are designed to be accessible, high-energy, and genuinely fun — suitable for all ages, all fitness levels, and people who are convinced they have no rhythm whatsoever (they always surprise themselves).
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-6">
            Available for team days, conferences, off-sites, company milestones, and end-of-year celebrations. Chewy provides all equipment and handles all logistics.
          </p>
          <div class="flex flex-wrap gap-3">
            <span class="px-3 py-1.5 bg-gold/10 text-gold-dark rounded-full text-xs font-medium">Team days</span>
            <span class="px-3 py-1.5 bg-gold/10 text-gold-dark rounded-full text-xs font-medium">Conferences</span>
            <span class="px-3 py-1.5 bg-gold/10 text-gold-dark rounded-full text-xs font-medium">Off-sites</span>
            <span class="px-3 py-1.5 bg-gold/10 text-gold-dark rounded-full text-xs font-medium">End-of-year events</span>
          </div>
        </div>
        <div class="reveal reveal-delay-2">
          <div class="rounded-3xl bg-linen aspect-[4/3] flex items-center justify-center relative overflow-hidden">
            <svg class="w-20 h-20 text-gold/20" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="0.75">
              <circle cx="24" cy="24" r="22"/><circle cx="24" cy="24" r="16"/>
              <circle cx="24" cy="24" r="10"/><circle cx="24" cy="24" r="4" fill="currentColor"/>
            </svg>
            <p class="absolute bottom-4 text-stone/50 text-xs">Corporate session photo coming soon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-20 lg:py-28 bg-linen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-gold-dark uppercase tracking-widest mb-3">Why it works</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">What your team gains</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {benefits.map((b, i) => (
          <div class:list={['reveal', `reveal-delay-${(i % 3) + 1}`, 'bg-cream rounded-2xl p-6 border border-linen']}>
            <h3 class="font-heading text-lg font-semibold text-charcoal mb-2">{b.title}</h3>
            <p class="text-sm text-charcoal/60 leading-relaxed">{b.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Formats -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Session formats</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">Choose your format</h2>
        <p class="text-charcoal/60 mt-3 max-w-xl mx-auto">All formats include full equipment provision, facilitation, and setup/packdown. Custom formats available on request.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {formats.map((f, i) => (
          <div class:list={['reveal', `reveal-delay-${i + 1}`, 'bg-linen rounded-2xl p-7 border border-linen']}>
            <h3 class="font-heading text-xl font-semibold text-charcoal mb-3">{f.title}</h3>
            <p class="text-sm text-charcoal/60 leading-relaxed mb-5">{f.description}</p>
            <div class="flex gap-4">
              <span class="flex items-center gap-1.5 text-xs text-charcoal/60">
                <svg class="w-3.5 h-3.5 text-sage-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {f.duration}
              </span>
              <span class="flex items-center gap-1.5 text-xs text-charcoal/60">
                <svg class="w-3.5 h-3.5 text-sage-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                {f.size}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="py-20 lg:py-28 bg-linen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Session flow</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">What to expect</h2>
      </div>
      <div class="space-y-6">
        {whatToExpect.map((step, i) => (
          <div class:list={['reveal', `reveal-delay-${i + 1}`, 'flex gap-5 items-start']}>
            <div class="shrink-0 w-12 h-12 rounded-full bg-charcoal flex items-center justify-center">
              <span class="font-heading text-sm font-semibold text-gold">{step.step}</span>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-charcoal mb-1">{step.title}</h3>
              <p class="text-sm text-charcoal/60 leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16 lg:py-20 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
      <TestimonialCard
        quote="We've tried lots of team-building activities over the years, but nothing has come close to the energy and genuine laughter that came out of our drumming session. Three months later, people are still mentioning it. Highly, highly recommend."
        author="David Park"
        role="People & Culture Manager"
        organization="Auckland technology company"
        featured={true}
      />
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="py-20 lg:py-28 bg-linen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div class="reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Book a corporate session</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">Ready to make some noise?</h2>
          <p class="text-charcoal/65 leading-relaxed mb-6">Tell me about your team, your timing, and your goals — I'll put together a session plan that fits.</p>
          <ul class="space-y-3">
            {['10–200+ participants', 'All equipment provided', 'Can come to your venue', 'Custom formats available'].map(item => (
              <li class="flex items-center gap-3 text-sm text-charcoal/70">
                <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal reveal-delay-2 bg-cream rounded-3xl p-8 border border-linen shadow-sm">
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-6">Enquire about corporate sessions</h3>
          <ContactForm preselectedService="Corporate Workshop" />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
