---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const preselectedService = Astro.url.searchParams.get('service') ?? '';

const faqs = [
  {
    q: 'How far in advance should I book?',
    a: 'For school term programmes, 4–6 weeks notice is ideal. For one-off events and workshops, 2–3 weeks is usually sufficient, though I do sometimes have last-minute availability. Corporate and large events (100+ people) benefit from 6–8 weeks lead time.',
  },
  {
    q: 'Do you bring all the equipment?',
    a: 'Yes — I bring everything needed for the session including all drums, percussion instruments, and any specialist equipment. You just need to provide a suitable space.',
  },
  {
    q: 'What space do you need?',
    a: 'A clear floor space approximately 1.5m per participant in a circle formation. Hard floors are ideal but carpet works fine. A school hall, community room, or large conference space all work well.',
  },
  {
    q: 'Can you accommodate large groups?',
    a: 'Yes — I regularly work with groups from 8 to 200+. For very large groups we discuss the format and layout in advance to make sure everyone has a genuine experience.',
  },
  {
    q: 'Are sessions available outside Auckland\'s North Shore?',
    a: 'I\'m primarily based on the North Shore and work across the wider Auckland region. For sessions further afield, get in touch and we can discuss travel arrangements.',
  },
  {
    q: 'Do you offer ongoing/repeat sessions?',
    a: 'Absolutely — many schools, rest homes, and disability services book regular weekly or fortnightly sessions. Ongoing arrangements are available at a discounted rate.',
  },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch with Rhythm for the Soul — book a drumming workshop, music therapy session, or event entertainment on Auckland's North Shore."
>

  <!-- Hero -->
  <section class="bg-linen py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Let's talk</p>
        <h1 class="font-heading text-4xl lg:text-5xl font-semibold text-charcoal mb-5">
          Get in touch
        </h1>
        <p class="text-charcoal/65 text-lg leading-relaxed">
          Whether you have a specific programme in mind or you're just exploring what's possible — I'd love to hear from you. No pressure, just a conversation about rhythm.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact section -->
  <section class="py-16 lg:py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- Contact info -->
        <div class="lg:col-span-2 reveal">
          <h2 class="font-heading text-2xl font-semibold text-charcoal mb-6">Contact details</h2>

          <div class="space-y-5 mb-10">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-linen flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-sage-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-medium text-charcoal/50 uppercase tracking-wide mb-1">Email</p>
                <a href="mailto:chewydrummer@hotmail.com" class="text-charcoal hover:text-gold transition-colors font-medium">
                  chewydrummer@hotmail.com
                </a>
                <p class="text-xs text-stone mt-1">I aim to reply within 1–2 business days</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-linen flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-sage-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-medium text-charcoal/50 uppercase tracking-wide mb-1">Phone</p>
                <a href="tel:+64274334627" class="text-charcoal hover:text-gold transition-colors font-medium">
                  +64 27 433 4627
                </a>
                <p class="text-xs text-stone mt-1">Available Mon–Fri, 9am–5pm NZT</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-linen flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-sage-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="text-xs font-medium text-charcoal/50 uppercase tracking-wide mb-1">Location</p>
                <p class="text-charcoal font-medium">Auckland's North Shore</p>
                <p class="text-xs text-stone mt-1">Serving the wider Auckland region</p>
              </div>
            </div>
          </div>

          <!-- Social -->
          <div>
            <p class="text-xs font-medium text-charcoal/50 uppercase tracking-wide mb-3">Follow along</p>
            <div class="flex gap-3">
              <a href="#" aria-label="Facebook" class="w-10 h-10 rounded-xl bg-linen flex items-center justify-center hover:bg-sage/20 transition-colors text-charcoal/60 hover:text-forest">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
              <a href="#" aria-label="Instagram" class="w-10 h-10 rounded-xl bg-linen flex items-center justify-center hover:bg-sage/20 transition-colors text-charcoal/60 hover:text-forest">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </a>
              <a href="#" aria-label="YouTube" class="w-10 h-10 rounded-xl bg-linen flex items-center justify-center hover:bg-sage/20 transition-colors text-charcoal/60 hover:text-forest">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.5 6.2a3.01 3.01 0 00-2.12-2.13C19.54 3.6 12 3.6 12 3.6s-7.54 0-9.38.47A3.01 3.01 0 00.5 6.2C.03 8.05 0 12 0 12s.03 3.95.5 5.8a3.01 3.01 0 002.12 2.13C4.46 20.4 12 20.4 12 20.4s7.54 0 9.38-.47a3.01 3.01 0 002.12-2.13c.47-1.85.5-5.8.5-5.8s-.03-3.95-.5-5.8zM9.75 15.5V8.5l6.25 3.5-6.25 3.5z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="lg:col-span-3 reveal reveal-delay-2">
          <div class="bg-linen rounded-3xl p-8 lg:p-10 border border-linen/80">
            <h2 class="font-heading text-2xl font-semibold text-charcoal mb-2">Send a message</h2>
            <p class="text-charcoal/55 text-sm mb-7">I'll get back to you within 1–2 business days.</p>
            <ContactForm preselectedService={preselectedService} showContactDetails={false} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-20 lg:py-28 bg-linen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Common questions</p>
        <h2 class="font-heading text-3xl font-semibold text-charcoal">Before you reach out</h2>
      </div>

      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <details
            class:list={['reveal', `reveal-delay-${(i % 3) + 1}`, 'group bg-cream border border-linen rounded-2xl overflow-hidden']}
          >
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-medium text-charcoal hover:text-forest transition-colors">
              <span>{faq.q}</span>
              <svg
                class="w-5 h-5 text-sage shrink-0 transition-transform duration-200 group-open:rotate-180"
                fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm text-charcoal/65 leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
