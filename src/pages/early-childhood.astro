---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
import TestimonialCard from '../components/TestimonialCard.astro';

const benefits = [
  { title: 'Language & communication', description: 'Rhythm, rhyme, and song are foundational to language development. Music sessions give young children rich, joyful exposure to sound patterns and vocabulary.' },
  { title: 'Motor development', description: 'Clapping, tapping, shaking, and moving to a beat builds both fine and gross motor coordination in a natural, playful way.' },
  { title: 'Emotional regulation', description: 'Gentle, predictable rhythms are inherently calming. Music helps children (and their caregivers) regulate mood, anxiety, and energy levels.' },
  { title: 'Parent-child bonding', description: 'Shared musical experiences create moments of genuine joy between caregivers and children — strengthening attachment through play.' },
  { title: 'Sensory exploration', description: 'Instruments offer rich sensory experiences — the feel of a drum skin, the rattle of seeds, the deep resonance of a bass note felt in the chest.' },
  { title: 'Social & group skills', description: 'Taking turns, sharing instruments, responding to a leader — even very young children build early social skills through structured group music play.' },
];

const whatToExpect = [
  { step: '01', title: 'Welcoming song', description: 'Every session opens with the same welcoming song — predictable ritual that signals safety and readiness for small children.' },
  { step: '02', title: 'Body percussion & movement', description: 'Clapping games, action rhymes, and moving to rhythm — activities that connect body and beat in accessible, playful ways.' },
  { step: '03', title: 'Instrument play', description: 'Small percussion instruments — shakers, bells, small drums, rhythm sticks — sized and chosen for little hands. Sensory exploration is encouraged.' },
  { step: '04', title: 'Storytelling through sound', description: 'Simple stories brought to life with percussion — rain falling, animals walking, thunder rolling. Imagination and listening woven together.' },
  { step: '05', title: 'Goodbye song & cool-down', description: 'A gentle, consistent closing ritual to signal the session\'s end and provide the transition support young children benefit from.' },
];
---

<BaseLayout
  title="Early Childhood Music Sessions"
  description="Music and rhythm sessions for children 0–5 on Auckland's North Shore. Joyful, sensory-rich experiences for tamariki and their whānau."
>

  <Hero
    eyebrow="Early childhood"
    title="Music & rhythm for little ones"
    subtitle="Joyful, sensory-rich sessions for tamariki aged 0–5 and their whānau"
    description="Gentle drumming, song, movement, and play — designed to delight young children while supporting language, motor development, and the precious bond between caregiver and child."
    ctaPrimary={{ label: 'Book an Early Childhood Session', href: '#contact' }}
    ctaSecondary={{ label: 'See all programmes', href: '/' }}
  />

  <!-- About -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">For our youngest</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">
            The first rhythms a child hears shape how they hear the world
          </h2>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            Children are born musical. From before birth, they're bathed in the rhythm of a heartbeat, the cadence of a voice, the patterns of language and song. Early music experiences don't just entertain — they wire young brains for learning, emotional resilience, and connection.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            These sessions are designed for children aged 0–5 accompanied by a parent, caregiver, or kaitiaki. The music is gentle, the pace is slow, and the instruments are chosen for little hands and curious minds.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-6">
            Sessions are available for early childhood centres, playgroups, Plunket groups, and private bookings.
          </p>
          <div class="flex flex-wrap gap-3">
            <span class="px-3 py-1.5 bg-sage/15 text-sage-dark rounded-full text-xs font-medium">Ages 0–5</span>
            <span class="px-3 py-1.5 bg-sage/15 text-sage-dark rounded-full text-xs font-medium">Caregiver joins in</span>
            <span class="px-3 py-1.5 bg-sage/15 text-sage-dark rounded-full text-xs font-medium">ECE centres</span>
            <span class="px-3 py-1.5 bg-sage/15 text-sage-dark rounded-full text-xs font-medium">Playgroups</span>
          </div>
        </div>
        <div class="reveal reveal-delay-2">
          <div class="rounded-3xl bg-linen aspect-[4/3] flex items-center justify-center relative overflow-hidden">
            <svg class="w-20 h-20 text-sage/20" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="0.75">
              <circle cx="24" cy="24" r="22"/><circle cx="24" cy="24" r="14"/>
              <circle cx="24" cy="24" r="7" fill="currentColor" opacity="0.3"/>
            </svg>
            <p class="absolute bottom-4 text-stone/50 text-xs">Session photo coming soon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-20 lg:py-28 bg-linen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Why it matters</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">The gifts of early music</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {benefits.map((b, i) => (
          <div class:list={['reveal', `reveal-delay-${(i % 3) + 1}`, 'bg-cream rounded-2xl p-6 border border-linen']}>
            <h3 class="font-heading text-lg font-semibold text-charcoal mb-2">{b.title}</h3>
            <p class="text-sm text-charcoal/60 leading-relaxed">{b.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Session structure</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">What to expect</h2>
        <p class="text-charcoal/60 mt-3">Sessions run 30–45 minutes, gentle enough for babies and engaging enough for five-year-olds.</p>
      </div>
      <div class="space-y-6">
        {whatToExpect.map((step, i) => (
          <div class:list={['reveal', `reveal-delay-${i + 1}`, 'flex gap-5 items-start']}>
            <div class="shrink-0 w-12 h-12 rounded-full bg-sage-light flex items-center justify-center">
              <span class="font-heading text-sm font-semibold text-forest">{step.step}</span>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-charcoal mb-1">{step.title}</h3>
              <p class="text-sm text-charcoal/60 leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16 lg:py-20 bg-linen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
      <TestimonialCard
        quote="My 2-year-old talks about 'the drum man' every day. She's started making up her own songs and rhythms at home. The sessions are so warmly facilitated — Chewy has a real gift with little ones."
        author="Priya Nair"
        role="Parent"
        organization="Playgroup, Takapuna"
        featured={true}
      />
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div class="reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Book a session</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">Give your tamariki the gift of rhythm</h2>
          <p class="text-charcoal/65 leading-relaxed mb-6">Available for ECE centres, Plunket groups, playgroups, and private family bookings. I come to you with all the instruments needed.</p>
          <ul class="space-y-3">
            {['Ages 0–5 with caregivers', 'Groups of up to 20 children', 'Suitable for all abilities', 'I come to your centre or venue'].map(item => (
              <li class="flex items-center gap-3 text-sm text-charcoal/70">
                <svg class="w-5 h-5 text-sage-dark shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal reveal-delay-2 bg-linen rounded-3xl p-8 border border-linen/80">
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-6">Enquire about early childhood sessions</h3>
          <ContactForm preselectedService="Early Childhood" />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
