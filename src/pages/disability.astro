---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
import TestimonialCard from '../components/TestimonialCard.astro';

const benefits = [
  { title: 'Non-verbal expression', description: 'For participants who find verbal communication challenging, rhythm offers a powerful, immediate, and valid form of self-expression.' },
  { title: 'Sensory regulation', description: 'The deep, predictable vibrations of hand drums can be profoundly regulating for people with sensory processing differences — grounding, centering, and calming.' },
  { title: 'Agency & choice', description: 'Participants always choose how and whether to engage. There is no wrong way to be in a drum circle — every contribution is celebrated.' },
  { title: 'Joyful engagement', description: 'Drum circles are simply fun. The laughter, the energy, the play — these are therapeutic in themselves, regardless of any clinical outcome.' },
  { title: 'Social participation', description: 'Being part of something bigger — making music together — offers a meaningful form of social inclusion that many participants find rare and precious.' },
  { title: 'Adaptive facilitation', description: 'Sessions are adapted in real time to the needs and energy of the group. Instruments, pace, volume, and structure can all be adjusted.' },
];

const whatToExpect = [
  { step: '01', title: 'Orientation & consent', description: 'Before the session, Chewy takes time to understand the group\'s needs, communication styles, and any sensory or physical considerations.' },
  { step: '02', title: 'Gentle opening', description: 'Sessions begin softly — quiet rhythms, familiar sounds, and a warm, non-pressured invitation to participate at whatever level feels right.' },
  { step: '03', title: 'Instrument exploration', description: 'Participants are invited to explore instruments at their own pace. Touch, sound, and sensation are all part of the experience — there is no rush to "play".' },
  { step: '04', title: 'Shared rhythm-making', description: 'As the group finds its groove, we build shared rhythms together — call and response, echo patterns, and free improvisation as the energy allows.' },
  { step: '05', title: 'Gentle close', description: 'Sessions close with a gradual wind-down — bringing the energy back to calm and offering space for any communication or sharing the group wishes to offer.' },
];
---

<BaseLayout
  title="Disability & Neurodiverse Drumming Sessions"
  description="Inclusive, adaptive drumming sessions for people with physical, intellectual, and sensory disabilities, autism, ADHD and more. Auckland's North Shore."
>

  <Hero
    eyebrow="Inclusive & adaptive"
    title="Rhythm for every body, every mind"
    subtitle="Inclusive drumming sessions designed around the needs of each unique group"
    description="Adaptive, sensory-informed percussion sessions for people with physical, intellectual, or sensory disabilities — and for neurodiverse participants including those with autism and ADHD."
    ctaPrimary={{ label: 'Book an Inclusive Session', href: '#contact' }}
    ctaSecondary={{ label: 'See all programmes', href: '/' }}
  />

  <!-- About -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Inclusive by design</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">
            The drum circle has no barriers — only open doors
          </h2>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            Rhythm is one of the most accessible forms of human expression. You don't need words, coordination, or prior experience. You don't need to be able to hear in a conventional sense, or move in a conventional way. You just need to be present — and the rhythm will meet you there.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-4">
            These sessions are designed specifically for participants with physical disabilities, intellectual disabilities, autism spectrum conditions, ADHD, sensory processing differences, and other neurodiverse needs. Every session is adapted to the group — never the other way around.
          </p>
          <p class="text-charcoal/65 leading-relaxed mb-6">
            Chewy works in consultation with support workers, carers, and organisations to understand what genuine inclusion looks like for each group, and delivers sessions that feel both safe and genuinely alive.
          </p>
          <div class="flex flex-wrap gap-3">
            <span class="px-3 py-1.5 bg-forest/10 text-forest rounded-full text-xs font-medium">Autism-friendly</span>
            <span class="px-3 py-1.5 bg-forest/10 text-forest rounded-full text-xs font-medium">Sensory-informed</span>
            <span class="px-3 py-1.5 bg-forest/10 text-forest rounded-full text-xs font-medium">Adaptive instruments</span>
            <span class="px-3 py-1.5 bg-forest/10 text-forest rounded-full text-xs font-medium">ADHD-aware</span>
          </div>
        </div>
        <div class="reveal reveal-delay-2">
          <div class="rounded-3xl bg-linen aspect-[4/3] flex items-center justify-center relative overflow-hidden">
            <svg class="w-20 h-20 text-forest/15" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="0.75">
              <circle cx="24" cy="24" r="22"/><circle cx="24" cy="24" r="16"/>
              <circle cx="24" cy="24" r="10"/><circle cx="24" cy="24" r="4" fill="currentColor"/>
            </svg>
            <p class="absolute bottom-4 text-stone/50 text-xs">Session photo coming soon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-20 lg:py-28 bg-linen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">What participants experience</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">Why rhythm works for everyone</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {benefits.map((b, i) => (
          <div class:list={['reveal', `reveal-delay-${(i % 3) + 1}`, 'bg-cream rounded-2xl p-6 border border-linen']}>
            <h3 class="font-heading text-lg font-semibold text-charcoal mb-2">{b.title}</h3>
            <p class="text-sm text-charcoal/60 leading-relaxed">{b.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Session structure</p>
        <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal">What to expect</h2>
        <p class="text-charcoal/60 mt-3">Every session is tailored. This is a general guide — the actual session adapts to your group's energy, needs, and pace.</p>
      </div>
      <div class="space-y-6">
        {whatToExpect.map((step, i) => (
          <div class:list={['reveal', `reveal-delay-${i + 1}`, 'flex gap-5 items-start']}>
            <div class="shrink-0 w-12 h-12 rounded-full bg-forest flex items-center justify-center">
              <span class="font-heading text-sm font-semibold text-cream">{step.step}</span>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-charcoal mb-1">{step.title}</h3>
              <p class="text-sm text-charcoal/60 leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16 lg:py-20 bg-linen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
      <TestimonialCard
        quote="Our clients with quite significant communication differences were engaged and expressive in a way we rarely see in other activities. Chewy has an incredible ability to meet people exactly where they are — no pressure, no agenda, just music and joy."
        author="Tama Hēmi"
        role="Support Services Coordinator"
        organization="North Shore disability support service"
        featured={true}
      />
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="py-20 lg:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div class="reveal">
          <p class="text-xs font-medium text-sage-dark uppercase tracking-widest mb-3">Book a session</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-charcoal mb-5">Let's create something inclusive together</h2>
          <p class="text-charcoal/65 leading-relaxed mb-6">Get in touch to discuss your group's specific needs — I'll come back with a session plan designed around them.</p>
          <ul class="space-y-3">
            {['All abilities and communication styles welcome', 'Adaptive instruments available', 'Collaboration with support workers welcome', 'Private, day programme, and residential settings'].map(item => (
              <li class="flex items-center gap-3 text-sm text-charcoal/70">
                <svg class="w-5 h-5 text-forest shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="reveal reveal-delay-2 bg-linen rounded-3xl p-8 border border-linen/80">
          <h3 class="font-heading text-xl font-semibold text-charcoal mb-6">Enquire about inclusive sessions</h3>
          <ContactForm preselectedService="Disability Sessions" />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
