---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="School Holidays"
  description="School holiday drumming programmes on Auckland's North Shore. Rhythm for the Soul runs fun, engaging workshops for kids and teens during school breaks."
>
  <div class="flex min-h-screen items-center justify-center px-6" style="padding-top: 7rem; padding-bottom: 4rem;">
    <div class="text-center">
      <p class="mb-5 text-xs font-semibold uppercase text-sage" style="letter-spacing: 0.2em; font-family: 'DM Sans', sans-serif;">Events &amp; Entertainment</p>
      <h1 class="font-heading text-cream" style="font-size: clamp(3.5rem, 7vw, 6rem); line-height: 1; letter-spacing: -0.02em;">School Holidays</h1>
    </div>
  </div>
</BaseLayout>
