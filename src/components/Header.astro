---
const currentPath = Astro.url.pathname;

const programmes = [
  { label: 'DRUMBEAT', href: '/drumbeat', desc: 'Evidence-based youth programme' },
  { label: 'Schools', href: '/schools', desc: 'Primary & intermediate workshops' },
  { label: 'Early Childhood', href: '/early-childhood', desc: 'Sessions for 0–5 year olds' },
  { label: 'Rest Homes', href: '/rest-homes', desc: 'Aged care & residential settings' },
  { label: 'Disability', href: '/disability', desc: 'Inclusive & neurodiverse sessions' },
];

const corporateEvents = [
  { label: 'Corporate', href: '/corporate', desc: 'Team building through rhythm' },
  { label: 'Events', href: '/events', desc: 'Parties, fire shows & sound journeys' },
];

function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header
  id="site-header"
  class="top-0 z-50"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group shrink-0" aria-label="Rhythm for the Soul — return to homepage">
        <img src="/logo.svg" alt="" class="h-10 w-auto" aria-hidden="true" />
        <span class="sr-only">Rhythm for the Soul</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1 xl:gap-2" aria-label="Main navigation">

        <!-- Programmes dropdown -->
        <div class="relative group/prog" data-dropdown>
          <button
            class:list={[
              'flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-lg transition-colors',
              programmes.some(p => isActive(p.href))
                ? 'text-forest bg-forest/10'
                : 'text-charcoal/70 hover:text-charcoal hover:bg-black/5',
            ]}
            aria-haspopup="true"
          >
            Programmes
            <svg class="w-3.5 h-3.5 mt-0.5 transition-transform duration-200 group-hover/prog:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div class="absolute left-1/2 -translate-x-1/2 top-full pt-2 opacity-0 invisible group-hover/prog:opacity-100 group-hover/prog:visible transition-all duration-200 translate-y-1 group-hover/prog:translate-y-0 w-64">
            <div class="bg-white border border-linen rounded-2xl shadow-xl overflow-hidden py-2">
              {programmes.map(item => (
                <a
                  href={item.href}
                  class:list={[
                    'block px-4 py-3 transition-colors',
                    isActive(item.href)
                      ? 'bg-forest/10 text-forest'
                      : 'hover:bg-black/5 text-charcoal',
                  ]}
                >
                  <span class="block text-sm font-medium">{item.label}</span>
                  <span class="block text-xs text-charcoal/50 mt-0.5">{item.desc}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Corporate & Events dropdown -->
        <div class="relative group/corp" data-dropdown>
          <button
            class:list={[
              'flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-lg transition-colors',
              corporateEvents.some(p => isActive(p.href))
                ? 'text-forest bg-forest/10'
                : 'text-charcoal/70 hover:text-charcoal hover:bg-black/5',
            ]}
            aria-haspopup="true"
          >
            Corporate & Events
            <svg class="w-3.5 h-3.5 mt-0.5 transition-transform duration-200 group-hover/corp:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div class="absolute left-1/2 -translate-x-1/2 top-full pt-2 opacity-0 invisible group-hover/corp:opacity-100 group-hover/corp:visible transition-all duration-200 translate-y-1 group-hover/corp:translate-y-0 w-56">
            <div class="bg-white border border-linen rounded-2xl shadow-xl overflow-hidden py-2">
              {corporateEvents.map(item => (
                <a
                  href={item.href}
                  class:list={[
                    'block px-4 py-3 transition-colors',
                    isActive(item.href)
                      ? 'bg-forest/10 text-forest'
                      : 'hover:bg-black/5 text-charcoal',
                  ]}
                >
                  <span class="block text-sm font-medium">{item.label}</span>
                  <span class="block text-xs text-charcoal/50 mt-0.5">{item.desc}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- About -->
        <a
          href="/about"
          class:list={[
            'px-3 py-2 text-sm font-medium rounded-lg transition-colors',
            isActive('/about')
              ? 'text-forest bg-forest/10'
              : 'text-charcoal/70 hover:text-charcoal hover:bg-black/5',
          ]}
        >
          About
        </a>

        <!-- Contact CTA -->
        <a
          href="/contact"
          class="ml-3 px-5 py-2.5 bg-forest text-cream rounded-full text-sm font-medium hover:bg-charcoal transition-colors shadow-sm"
        >
          Get in Touch
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="hamburger"
        class="lg:hidden flex flex-col justify-center gap-1.5 w-10 h-10 p-2 rounded-lg hover:bg-black/5 transition-colors"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="block w-full h-0.5 bg-charcoal rounded-full transition-all duration-300 origin-center" id="ham-1"></span>
        <span class="block w-full h-0.5 bg-charcoal rounded-full transition-all duration-300" id="ham-2"></span>
        <span class="block w-4/5 h-0.5 bg-charcoal rounded-full transition-all duration-300 origin-center" id="ham-3"></span>
      </button>
    </div>
  </div>
</header>

<style>
  /* ── Base: fixed, transparent over hero ──────────────────── */
  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background-color: transparent;
    border-bottom: 1px solid transparent;
    transition: background-color 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  /* ── Scrolled: cream fill ────────────────────────────────── */
  #site-header.is-scrolled {
    background-color: #F5F0E8;
    border-bottom-color: rgba(46, 49, 65, 0.08);
    box-shadow: 0 1px 12px rgba(46, 49, 65, 0.04);
  }

  /* ── Desktop nav text: cream over photo ─────────────────── */
  /* Targets direct-child nav links (About) and dropdown trigger
     buttons only — deliberately skips dropdown panel links
     (not direct children) and the CTA pill (has bg-forest class) */
  #site-header nav > a:not([class*="bg-forest"]),
  #site-header nav [data-dropdown] > button {
    color: rgba(245, 240, 232, 0.92);
  }

  /* ── Desktop nav text: charcoal once scrolled ───────────── */
  #site-header.is-scrolled nav > a:not([class*="bg-forest"]),
  #site-header.is-scrolled nav [data-dropdown] > button {
    color: #2E3141;
  }

  /* ── Hamburger bars: cream / charcoal ───────────────────── */
  #ham-1, #ham-2, #ham-3 {
    background-color: #F5F0E8;
  }
  #site-header.is-scrolled #ham-1,
  #site-header.is-scrolled #ham-2,
  #site-header.is-scrolled #ham-3 {
    background-color: #2E3141;
  }
</style>

<!-- ── Mobile menu overlay ───────────────────────────────── -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-navy flex flex-col lg:hidden transition-all duration-300 opacity-0 invisible"
  aria-hidden="true"
  role="dialog"
  aria-label="Navigation menu"
>
  <!-- Mobile header bar -->
  <div class="flex items-center justify-between px-4 sm:px-6 h-16 border-b border-white/10 shrink-0">
    <a href="/" class="font-heading text-lg font-semibold text-cream">
      Rhythm <span class="text-clay">for the Soul</span>
    </a>
    <button
      id="close-menu"
      class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-white/10 transition-colors text-cream"
      aria-label="Close navigation menu"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav links -->
  <nav class="flex-1 overflow-y-auto px-4 sm:px-6 py-8" aria-label="Mobile navigation">
    <!-- Programmes group -->
    <p class="text-xs font-medium text-sage-light uppercase tracking-widest mb-4">Programmes</p>
    <ul class="flex flex-col gap-1 mb-8">
      {programmes.map(item => (
        <li>
          <a
            href={item.href}
            class="flex items-center justify-between py-3 border-b border-white/10 group"
          >
            <span class="font-heading text-2xl font-light text-cream/80 group-hover:text-cream transition-colors">
              {item.label}
            </span>
            <svg class="w-5 h-5 text-sage-light opacity-40 group-hover:opacity-100 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </li>
      ))}
    </ul>

    <!-- Corporate & Events group -->
    <p class="text-xs font-medium text-sage-light uppercase tracking-widest mb-4">Corporate & Events</p>
    <ul class="flex flex-col gap-1 mb-8">
      {corporateEvents.map(item => (
        <li>
          <a
            href={item.href}
            class="flex items-center justify-between py-3 border-b border-white/10 group"
          >
            <span class="font-heading text-2xl font-light text-cream/80 group-hover:text-cream transition-colors">
              {item.label}
            </span>
            <svg class="w-5 h-5 text-sage-light opacity-40 group-hover:opacity-100 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </li>
      ))}
    </ul>

    <!-- Single links -->
    <ul class="flex flex-col gap-1 mb-10">
      <li>
        <a href="/about" class="flex items-center justify-between py-3 border-b border-white/10 group">
          <span class="font-heading text-2xl font-light text-cream/80 group-hover:text-cream transition-colors">About</span>
          <svg class="w-5 h-5 text-sage-light opacity-40 group-hover:opacity-100 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </li>
      <li>
        <a href="/testimonials" class="flex items-center justify-between py-3 border-b border-white/10 group">
          <span class="font-heading text-2xl font-light text-cream/80 group-hover:text-cream transition-colors">Testimonials</span>
          <svg class="w-5 h-5 text-sage-light opacity-40 group-hover:opacity-100 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </li>
    </ul>

    <a href="/contact" class="inline-block px-8 py-4 bg-forest text-cream rounded-full font-medium text-base hover:bg-charcoal transition-colors">
      Get in Touch
    </a>
  </nav>
</div>

<script>
  const hamburger = document.getElementById('hamburger')!;
  const closeBtn = document.getElementById('close-menu')!;
  const menu = document.getElementById('mobile-menu')!;
  const ham1 = document.getElementById('ham-1')!;
  const ham2 = document.getElementById('ham-2')!;
  const ham3 = document.getElementById('ham-3')!;

  function open() {
    menu.classList.remove('opacity-0', 'invisible');
    menu.classList.add('opacity-100');
    menu.setAttribute('aria-hidden', 'false');
    hamburger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    ham1.style.transform = 'translateY(8px) rotate(45deg)';
    ham2.style.opacity = '0';
    ham3.style.transform = 'translateY(-8px) rotate(-45deg)';
    ham3.style.width = '100%';
  }

  function close() {
    menu.classList.add('opacity-0', 'invisible');
    menu.classList.remove('opacity-100');
    menu.setAttribute('aria-hidden', 'true');
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    ham1.style.transform = '';
    ham2.style.opacity = '';
    ham3.style.transform = '';
    ham3.style.width = '';
  }

  hamburger.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
  menu.querySelectorAll('a').forEach(a => a.addEventListener('click', close));

  const header = document.getElementById('site-header')!;
  window.addEventListener('scroll', () => {
    header.classList.toggle('is-scrolled', window.scrollY > 80);
  }, { passive: true });
</script>
