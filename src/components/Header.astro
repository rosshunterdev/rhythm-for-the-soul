---
const currentPath = Astro.url.pathname;

const programmes = [
  { label: 'DRUMBEAT', href: '/drumbeat', desc: 'Evidence-based youth programme' },
  { label: 'Schools', href: '/schools', desc: 'Primary & intermediate workshops' },
  { label: 'Early Childhood', href: '/early-childhood', desc: 'Sessions for 0–5 year olds' },
  { label: 'Rest Homes', href: '/rest-homes', desc: 'Aged care & residential settings' },
  { label: 'Disability', href: '/disability', desc: 'Inclusive & neurodiverse sessions' },
];

const corporateEvents = [
  { label: 'Corporate', href: '/corporate', desc: 'Team building through rhythm' },
  { label: 'Events', href: '/events', desc: 'Parties, fire shows & sound journeys' },
];

function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header id="site-header" class="z-50" role="banner">
  <div class="nav-inner">

    <!-- Logo — far left -->
    <div class="nav-logo-slot">
      <a href="/" aria-label="Rhythm for the Soul — home">
        <img src="/logo.png" alt="Rhythm for the Soul" class="logo-img" />
      </a>
    </div>

    <!-- Desktop nav — centred -->
    <nav class="nav-desktop" aria-label="Main navigation">

      <!-- Programmes dropdown -->
      <div class="relative group/prog" data-dropdown>
        <button
          class:list={['nav-link', programmes.some(p => isActive(p.href)) && 'is-active']}
          aria-haspopup="true"
          aria-expanded="false"
        >
          Programmes
          <svg
            class="chevron group-hover/prog:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div class="absolute left-1/2 -translate-x-1/2 top-full pt-2.5 z-10 opacity-0 invisible translate-y-1 group-hover/prog:opacity-100 group-hover/prog:visible group-hover/prog:translate-y-0 transition-all duration-200">
          <div class="dropdown-card" style="width: 260px">
            {programmes.map(item => (
              <a
                href={item.href}
                class:list={['dropdown-link', isActive(item.href) && 'is-active']}
              >
                <span class="dropdown-label">{item.label}</span>
                <span class="dropdown-desc">{item.desc}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Corporate & Events dropdown -->
      <div class="relative group/corp" data-dropdown>
        <button
          class:list={['nav-link', corporateEvents.some(p => isActive(p.href)) && 'is-active']}
          aria-haspopup="true"
          aria-expanded="false"
        >
          Corporate &amp; Events
          <svg
            class="chevron group-hover/corp:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div class="absolute left-1/2 -translate-x-1/2 top-full pt-2.5 z-10 opacity-0 invisible translate-y-1 group-hover/corp:opacity-100 group-hover/corp:visible group-hover/corp:translate-y-0 transition-all duration-200">
          <div class="dropdown-card" style="width: 224px">
            {corporateEvents.map(item => (
              <a
                href={item.href}
                class:list={['dropdown-link', isActive(item.href) && 'is-active']}
              >
                <span class="dropdown-label">{item.label}</span>
                <span class="dropdown-desc">{item.desc}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- About -->
      <a
        href="/about"
        class:list={['nav-link', isActive('/about') && 'is-active']}
      >
        About
      </a>
    </nav>

    <!-- CTA + hamburger — far right -->
    <div class="nav-right-slot">
      <a href="/contact" class="cta-btn">Get in Touch</a>

      <button
        id="hamburger"
        class="hamburger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span id="ham-1"></span>
        <span id="ham-2"></span>
        <span id="ham-3"></span>
      </button>
    </div>
  </div>
</header>

<style>
  /* ── Pill ── */
  #site-header {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 32px);
    max-width: 760px;
    height: 60px;
    border-radius: 999px;
    /* Glass effect lives on ::before so logo mix-blend-mode
       composes against the page, not a backdrop-filter group */
  }

  #site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: rgba(245, 240, 232, 0.82);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(46, 49, 65, 0.10);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.14);
    transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    z-index: -1;
    pointer-events: none;
  }

  #site-header.nav--scrolled::before {
    background: rgba(245, 240, 232, 0.97);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.18);
    border-color: rgba(46, 49, 65, 0.13);
  }

  /* ── Three-column inner layout ── */
  .nav-inner {
    position: relative;
    display: flex;
    align-items: center;
    height: 100%;
    padding: 0 20px;
    gap: 8px;
  }

  .nav-logo-slot {
    flex: 1;
    min-width: 0;
  }

  .nav-right-slot {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 12px;
  }

  /* ── Logo ── */
  .logo-img {
    height: 42px;
    width: auto;
    display: block;
    filter: invert(1);
    mix-blend-mode: multiply;
  }

  /* ── Desktop nav ── */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }

  @media (min-width: 1024px) {
    .nav-desktop { display: flex; }
  }

  /* ── Nav links ── */
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 7px 13px;
    font-size: 13.5px;
    font-weight: 500;
    color: rgba(46, 49, 65, 0.62);
    background: transparent;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    font-family: inherit;
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: 0.01em;
    transition: color 0.15s, background 0.15s;
  }

  .nav-link:hover {
    color: rgba(46, 49, 65, 1);
    background: rgba(46, 49, 65, 0.07);
  }

  .nav-link.is-active {
    color: rgba(46, 49, 65, 1);
    background: rgba(46, 49, 65, 0.09);
  }

  /* ── Chevron ── */
  .chevron {
    width: 13px;
    height: 13px;
    opacity: 0.5;
    flex-shrink: 0;
    margin-top: 1px;
    transition: transform 0.2s ease, opacity 0.15s;
  }

  .nav-link:hover .chevron {
    opacity: 0.85;
  }

  /* ── Dropdown card ── */
  .dropdown-card {
    background: rgba(35, 38, 52, 0.98);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(196, 168, 130, 0.20);
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.30), 0 2px 8px rgba(0, 0, 0, 0.15);
    padding: 6px;
  }

  .dropdown-link {
    display: block;
    padding: 10px 12px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .dropdown-link:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .dropdown-link.is-active {
    background: rgba(255, 255, 255, 0.10);
  }

  .dropdown-label {
    display: block;
    font-size: 13.5px;
    font-weight: 500;
    color: rgba(245, 240, 232, 0.90);
    letter-spacing: 0.01em;
  }

  .dropdown-desc {
    display: block;
    font-size: 12px;
    color: rgba(196, 168, 130, 0.72);
    margin-top: 2px;
    line-height: 1.4;
  }

  /* ── CTA button ── */
  .cta-btn {
    display: none;
    align-items: center;
    padding: 8px 18px;
    background: #4A7C59;
    color: #F5F0E8;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: 0.02em;
    box-shadow: 0 2px 8px rgba(74, 124, 89, 0.30);
    transition: background 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  @media (min-width: 1024px) {
    .cta-btn { display: inline-flex; }
  }

  .cta-btn:hover {
    background: #5E9370;
    box-shadow: 0 4px 14px rgba(74, 124, 89, 0.40);
    transform: translateY(-1px);
  }

  .cta-btn:active {
    background: #3A5E48;
    transform: translateY(0);
    box-shadow: 0 1px 6px rgba(74, 124, 89, 0.25);
  }

  .cta-btn:focus-visible {
    outline: 2px solid rgba(74, 124, 89, 0.65);
    outline-offset: 3px;
  }

  /* ── Hamburger ── */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 40px;
    height: 40px;
    padding: 10px 8px;
    border-radius: 8px;
    background: none;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
  }

  @media (min-width: 1024px) {
    .hamburger { display: none; }
  }

  .hamburger:hover {
    background: rgba(46, 49, 65, 0.07);
  }

  .hamburger span {
    display: block;
    height: 1.5px;
    width: 100%;
    background: rgba(46, 49, 65, 0.80);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease, width 0.25s ease;
  }

  #ham-3 {
    width: 75%;
  }
</style>

<!-- ── Mobile menu overlay ── -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 bg-navy flex flex-col lg:hidden transition-all duration-300 opacity-0 invisible"
  aria-hidden="true"
  role="dialog"
  aria-label="Navigation menu"
>
  <!-- Mobile header bar -->
  <div class="flex items-center justify-between px-4 sm:px-6 h-16 border-b border-white/10 shrink-0">
    <a href="/" class="font-heading text-lg font-semibold text-cream">
      Rhythm <span class="text-clay">for the Soul</span>
    </a>
    <button
      id="close-menu"
      class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-white/10 transition-colors text-cream"
      aria-label="Close navigation menu"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav links -->
  <nav class="flex-1 overflow-y-auto px-4 sm:px-6 py-8" aria-label="Mobile navigation">
    <!-- Programmes group -->
    <p class="text-xs font-medium text-sage-light uppercase tracking-widest mb-4">Programmes</p>
    <ul class="flex flex-col gap-1 mb-8">
      {programmes.map(item => (
        <li>
          <a
            href={item.href}
            class="flex items-center justify-between py-3 border-b border-white/10 group"
          >
            <span class="font-heading text-2xl font-light text-cream/80 group-hover:text-cream transition-colors">
              {item.label}
            </span>
            <svg class="w-5 h-5 text-sage-light opacity-40 group-hover:opacity-100 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </li>
      ))}
    </ul>

    <!-- Corporate & Events group -->
    <p class="text-xs font-medium text-sage-light uppercase tracking-widest mb-4">Corporate &amp; Events</p>
    <ul class="flex flex-col gap-1 mb-8">
      {corporateEvents.map(item => (
        <li>
          <a
            href={item.href}
            class="flex items-center justify-between py-3 border-b border-white/10 group"
          >
            <span class="font-heading text-2xl font-light text-cream/80 group-hover:text-cream transition-colors">
              {item.label}
            </span>
            <svg class="w-5 h-5 text-sage-light opacity-40 group-hover:opacity-100 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </li>
      ))}
    </ul>

    <!-- Single links -->
    <ul class="flex flex-col gap-1 mb-10">
      <li>
        <a href="/about" class="flex items-center justify-between py-3 border-b border-white/10 group">
          <span class="font-heading text-2xl font-light text-cream/80 group-hover:text-cream transition-colors">About</span>
          <svg class="w-5 h-5 text-sage-light opacity-40 group-hover:opacity-100 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </li>
      <li>
        <a href="/testimonials" class="flex items-center justify-between py-3 border-b border-white/10 group">
          <span class="font-heading text-2xl font-light text-cream/80 group-hover:text-cream transition-colors">Testimonials</span>
          <svg class="w-5 h-5 text-sage-light opacity-40 group-hover:opacity-100 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </li>
    </ul>

    <a href="/contact" class="inline-block px-8 py-4 bg-forest text-cream rounded-full font-medium text-base hover:bg-charcoal transition-colors">
      Get in Touch
    </a>
  </nav>
</div>

<script>
  const hamburger = document.getElementById('hamburger')!;
  const closeBtn = document.getElementById('close-menu')!;
  const menu = document.getElementById('mobile-menu')!;
  const ham1 = document.getElementById('ham-1')!;
  const ham2 = document.getElementById('ham-2')!;
  const ham3 = document.getElementById('ham-3')!;

  function open() {
    menu.classList.remove('opacity-0', 'invisible');
    menu.classList.add('opacity-100');
    menu.setAttribute('aria-hidden', 'false');
    hamburger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    ham1.style.transform = 'translateY(8px) rotate(45deg)';
    ham2.style.opacity = '0';
    ham3.style.transform = 'translateY(-8px) rotate(-45deg)';
    ham3.style.width = '100%';
  }

  function close() {
    menu.classList.add('opacity-0', 'invisible');
    menu.classList.remove('opacity-100');
    menu.setAttribute('aria-hidden', 'true');
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    ham1.style.transform = '';
    ham2.style.opacity = '';
    ham3.style.transform = '';
    ham3.style.width = '';
  }

  hamburger.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
  menu.querySelectorAll('a').forEach(a => a.addEventListener('click', close));

  const header = document.getElementById('site-header')!;
  window.addEventListener('scroll', () => {
    header.classList.toggle('nav--scrolled', window.scrollY > 80);
  }, { passive: true });
</script>
