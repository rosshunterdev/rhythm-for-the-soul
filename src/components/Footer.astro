---
import ContactForm from './ContactForm.astro';

const programmes = [
  { label: 'DRUMBEAT', href: '/drumbeat' },
  { label: 'Schools', href: '/schools' },
  { label: 'Early Childhood', href: '/early-childhood' },
  { label: 'Rest Homes', href: '/rest-homes' },
  { label: 'Disability', href: '/disability' },
];

const more = [
  { label: 'Corporate', href: '/corporate' },
  { label: 'Events', href: '/events' },
  { label: 'About Chewy', href: '/about' },
  { label: 'Testimonials', href: '/testimonials' },
  { label: 'Contact', href: '/contact' },
];

const year = new Date().getFullYear();
---

<footer class="bg-charcoal text-cream">

  <!-- Contact form strip -->
  <div class="border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div>
          <p class="text-xs font-medium text-sage-light uppercase tracking-widest mb-3">Say hello</p>
          <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-cream mb-4">
            Let's find the right rhythm for you
          </h2>
          <p class="text-cream/65 leading-relaxed max-w-md">
            Whether you have a specific programme in mind or just want to explore what's possible,
            I'd love to hear from you. No pressure — just a conversation.
          </p>

          <!-- Contact details -->
          <div class="mt-8 space-y-3">
            <a href="mailto:chewydrummer@hotmail.com" class="flex items-center gap-3 text-cream/70 hover:text-gold transition-colors group text-sm">
              <svg class="w-4 h-4 text-sage shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              chewydrummer@hotmail.com
            </a>
            <a href="tel:+64274334627" class="flex items-center gap-3 text-cream/70 hover:text-gold transition-colors text-sm">
              <svg class="w-4 h-4 text-sage shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              +64 27 433 4627
            </a>
            <p class="flex items-center gap-3 text-cream/70 text-sm">
              <svg class="w-4 h-4 text-sage shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Auckland's North Shore, New Zealand
            </p>
          </div>

          <!-- Social links -->
          <div class="mt-6 flex gap-4">
            <a href="#" aria-label="Facebook" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-gold/20 hover:text-gold transition-colors text-cream/60">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a href="#" aria-label="Instagram" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-gold/20 hover:text-gold transition-colors text-cream/60">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
            <a href="#" aria-label="YouTube" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-gold/20 hover:text-gold transition-colors text-cream/60">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.5 6.2a3.01 3.01 0 00-2.12-2.13C19.54 3.6 12 3.6 12 3.6s-7.54 0-9.38.47A3.01 3.01 0 00.5 6.2C.03 8.05 0 12 0 12s.03 3.95.5 5.8a3.01 3.01 0 002.12 2.13C4.46 20.4 12 20.4 12 20.4s7.54 0 9.38-.47a3.01 3.01 0 002.12-2.13c.47-1.85.5-5.8.5-5.8s-.03-3.95-.5-5.8zM9.75 15.5V8.5l6.25 3.5-6.25 3.5z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Quick contact form -->
        <div>
          <ContactForm dark={true} compact={true} />
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-10">

      <!-- Brand -->
      <div>
        <a href="/" class="font-heading text-lg font-semibold text-cream block mb-3">
          Rhythm <span class="text-gold">for the Soul</span>
        </a>
        <p class="text-cream/50 text-xs leading-relaxed">
          Drumming workshops, music therapy, and live entertainment<br/>
          on Auckland's North Shore, New Zealand.
        </p>
      </div>

      <!-- Programmes -->
      <div>
        <p class="text-xs font-medium text-sage-light uppercase tracking-widest mb-4">Programmes</p>
        <ul class="space-y-2">
          {programmes.map(link => (
            <li>
              <a href={link.href} class="text-sm text-cream/55 hover:text-gold transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- More -->
      <div>
        <p class="text-xs font-medium text-sage-light uppercase tracking-widest mb-4">More</p>
        <ul class="space-y-2">
          {more.map(link => (
            <li>
              <a href={link.href} class="text-sm text-cream/55 hover:text-gold transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-2 text-cream/35 text-xs">
      <p>© {year} Rhythm for the Soul. All rights reserved.</p>
      <p>Designed & built in Aotearoa New Zealand.</p>
    </div>
  </div>
</footer>
