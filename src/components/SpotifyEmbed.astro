---
interface Props {
  playlistId?: string;
  title?: string;
}

const {
  // World percussion / drumming playlist — replace with Chewy's own playlist when available
  playlistId = '37i9dQZF1DX0SM0LYsmbMT',
  title = 'Rhythm for the Soul — curated playlist',
} = Astro.props;

const src = `https://open.spotify.com/embed/playlist/${playlistId}?utm_source=generator`;
---

<div class="w-full rounded-2xl overflow-hidden shadow-md" style="height: 152px;">
  <iframe
    src={src}
    {title}
    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
    loading="lazy"
    class="w-full h-full border-0"
  ></iframe>
</div>
