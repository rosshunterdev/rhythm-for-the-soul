---
interface Props {
  quote: string;
  author: string;
  organization?: string;
  role?: string;
  featured?: boolean;
}

const { quote, author, organization, role, featured = false } = Astro.props;
---

<figure
  class:list={[
    'rounded-2xl p-7 lg:p-8 flex flex-col',
    featured
      ? 'bg-charcoal text-cream border border-forest'
      : 'bg-linen border border-linen',
  ]}
>
  <!-- Quote mark -->
  <div class:list={['mb-4', featured ? 'text-gold' : 'text-sage']}>
    <svg width="32" height="24" viewBox="0 0 32 24" fill="currentColor" aria-hidden="true">
      <path d="M0 24V14.4C0 6.4 4.8 1.6 14.4 0l1.6 2.4C11.2 3.6 8.8 6.4 8 10.4h6.4V24H0zm17.6 0V14.4C17.6 6.4 22.4 1.6 32 0l1.6 2.4c-4.8 1.2-7.2 4-8 8h6.4V24H17.6z"/>
    </svg>
  </div>

  <blockquote class:list={[
    'flex-1 text-base lg:text-lg leading-relaxed italic font-light mb-6',
    featured ? 'text-cream/90' : 'text-charcoal/80',
  ]}>
    {quote}
  </blockquote>

  <figcaption>
    <p class:list={['font-medium text-sm', featured ? 'text-cream' : 'text-charcoal']}>
      {author}
    </p>
    {(role || organization) && (
      <p class:list={['text-xs mt-0.5', featured ? 'text-sage-light' : 'text-stone']}>
        {role}{role && organization ? ', ' : ''}{organization}
      </p>
    )}
  </figcaption>
</figure>
