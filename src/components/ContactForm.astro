---
interface Props {
  preselectedService?: string;
  compact?: boolean;
  dark?: boolean;
  showContactDetails?: boolean;
}

const {
  preselectedService = '',
  compact = false,
  dark = false,
  showContactDetails,
} = Astro.props;

// Show contact details unless explicitly overridden or in compact (footer) mode
const showDetails = showContactDetails ?? !compact;

// Resolves URL slug params (?service=drumbeat) to exact dropdown option values.
// Service pages pass the full label directly; the contact page passes whatever
// is in the URL query string, which may still be a slug.
const slugMap: Record<string, string> = {
  'drumbeat':        'DRUMBEAT',
  'schools':         'Schools Programme',
  'early-childhood': 'Early Childhood',
  'rest-homes':      'Rest Homes',
  'disability':      'Disability Sessions',
  'corporate':       'Corporate Workshop',
  'birthday-party':  'Birthday Party',
  'fire-show':       'Fire Show',
  'sound-journey':   'Sound Journey',
  'laughter-yoga':   'Laughter Yoga',
  'one-on-one':      'One-on-One Lessons',
  'other':           'Other',
};
const resolvedService = slugMap[preselectedService] ?? preselectedService;

const FORM_ID = 'xyzplaceholder';

const services = [
  { value: '',                   label: 'What can I help with?' },
  { value: 'DRUMBEAT',           label: 'DRUMBEAT' },
  { value: 'Schools Programme',  label: 'Schools Programme' },
  { value: 'Early Childhood',    label: 'Early Childhood' },
  { value: 'Rest Homes',         label: 'Rest Homes' },
  { value: 'Disability Sessions',label: 'Disability Sessions' },
  { value: 'Corporate Workshop', label: 'Corporate Workshop' },
  { value: 'Birthday Party',     label: 'Birthday Party' },
  { value: 'Fire Show',          label: 'Fire Show' },
  { value: 'Sound Journey',      label: 'Sound Journey' },
  { value: 'Laughter Yoga',      label: 'Laughter Yoga' },
  { value: 'One-on-One Lessons', label: 'One-on-One Lessons' },
  { value: 'Other',              label: 'Other' },
];

// Unique suffix so label `for` / input `id` pairs don't clash when
// two forms appear on the same page (e.g. page CTA + footer form).
const uid = Math.random().toString(36).slice(2, 7);

// Field styling
const fieldBase = 'w-full rounded-lg border px-4 py-3 text-sm transition-colors outline-none focus:ring-2';
const inputLight = 'bg-white border-sage/30 text-charcoal placeholder-stone/50 focus:border-sage focus:ring-sage/15';
const inputDark  = 'bg-white/10 border-white/20 text-cream placeholder-cream/40 focus:border-sage focus:ring-sage/20';
const inputClasses = dark ? inputDark : inputLight;
const labelClasses = dark ? 'text-cream/70' : 'text-charcoal/60';
const linkClasses  = dark
  ? 'text-cream/55 hover:text-sage-light'
  : 'text-charcoal/50 hover:text-forest';
---

<div data-form-wrapper>
  <form
    id={`contact-form-${uid}`}
    action={`https://formspree.io/f/${FORM_ID}`}
    method="POST"
    class:list={['space-y-4', compact ? '' : 'lg:space-y-5']}
    data-contact-form
  >
    <!-- Honeypot — hidden from humans, catches bots -->
    <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
    <input type="hidden" name="_subject" value="New enquiry — Rhythm for the Soul" />

    <!-- Row 1: Name + Email -->
    <div class:list={[compact ? 'space-y-4' : 'grid grid-cols-1 sm:grid-cols-2 gap-4']}>
      <div>
        <label
          for={`cf-name-${uid}`}
          class:list={['block text-xs font-medium mb-1.5 uppercase tracking-wide', labelClasses]}
        >
          Name <span class:list={[dark ? 'text-sage-light' : 'text-forest']}>*</span>
        </label>
        <input
          type="text"
          id={`cf-name-${uid}`}
          name="name"
          required
          autocomplete="name"
          placeholder="Your name"
          class:list={[fieldBase, inputClasses]}
        />
      </div>

      <div>
        <label
          for={`cf-email-${uid}`}
          class:list={['block text-xs font-medium mb-1.5 uppercase tracking-wide', labelClasses]}
        >
          Email <span class:list={[dark ? 'text-sage-light' : 'text-forest']}>*</span>
        </label>
        <input
          type="email"
          id={`cf-email-${uid}`}
          name="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
          class:list={[fieldBase, inputClasses]}
        />
      </div>
    </div>

    <!-- Row 2: Phone + Service -->
    <div class:list={[compact ? 'space-y-4' : 'grid grid-cols-1 sm:grid-cols-2 gap-4']}>
      <div>
        <label
          for={`cf-phone-${uid}`}
          class:list={['block text-xs font-medium mb-1.5 uppercase tracking-wide', labelClasses]}
        >
          Phone
          <span class:list={['font-normal normal-case ml-1', dark ? 'text-cream/35' : 'text-stone/50']}>
            (optional)
          </span>
        </label>
        <input
          type="tel"
          id={`cf-phone-${uid}`}
          name="phone"
          autocomplete="tel"
          placeholder="+64 27 433 4627"
          class:list={[fieldBase, inputClasses]}
        />
      </div>

      <div>
        <label
          for={`cf-service-${uid}`}
          class:list={['block text-xs font-medium mb-1.5 uppercase tracking-wide', labelClasses]}
        >
          Service
        </label>
        <div class="relative">
          <select
            id={`cf-service-${uid}`}
            name="service"
            class:list={[
              fieldBase,
              'appearance-none cursor-pointer pr-9',
              dark ? `${inputDark} bg-charcoal/50` : `${inputLight} bg-white`,
            ]}
          >
            {services.map(s => (
              <option
                value={s.value}
                selected={s.value === resolvedService || undefined}
                class="text-charcoal bg-white"
              >
                {s.label}
              </option>
            ))}
          </select>
          <svg
            class:list={['pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4', dark ? 'text-cream/40' : 'text-stone/50']}
            fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Message -->
    <div>
      <label
        for={`cf-message-${uid}`}
        class:list={['block text-xs font-medium mb-1.5 uppercase tracking-wide', labelClasses]}
      >
        Message <span class:list={[dark ? 'text-sage-light' : 'text-forest']}>*</span>
      </label>
      <textarea
        id={`cf-message-${uid}`}
        name="message"
        required
        rows={compact ? 3 : 5}
        placeholder="Tell me a bit about what you're looking for — group size, setting, any specific needs…"
        class:list={[fieldBase, inputClasses, 'resize-none']}
      ></textarea>
    </div>

    <!-- Submit + inline state messages -->
    <div class="flex flex-wrap items-center gap-4">
      <button
        type="submit"
        class:list={[
          'px-8 py-3.5 text-cream rounded-full font-medium text-sm transition-colors shadow-sm cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed',
          dark ? 'bg-forest hover:bg-charcoal' : 'bg-forest hover:bg-charcoal',
        ]}
        data-submit-btn
      >
        Send Message
      </button>

      <p
        class="hidden text-sm font-medium text-sage-dark"
        data-success-msg
        aria-live="polite"
      >
        ✓ Message sent — I'll be in touch within 1–2 business days.
      </p>
      <p
        class="hidden text-sm font-medium text-red-600"
        data-error-msg
        aria-live="polite"
      >
        Something went wrong — please try again or email me directly.
      </p>
    </div>
  </form>

  <!-- Contact details strip — shown below the form everywhere except compact/footer -->
  {showDetails && (
    <div
      class:list={[
        'mt-7 pt-6 border-t flex flex-col sm:flex-row sm:flex-wrap gap-4 sm:gap-x-8 text-sm',
        dark ? 'border-white/10' : 'border-sage/15',
      ]}
    >
      <a
        href="mailto:chewydrummer@hotmail.com"
        class:list={['flex items-center gap-2 transition-colors', linkClasses]}
      >
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        chewydrummer@hotmail.com
      </a>

      <a
        href="tel:+64274334627"
        class:list={['flex items-center gap-2 transition-colors', linkClasses]}
      >
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        +64 27 433 4627
      </a>

      <a
        href="https://www.facebook.com/rhythmforthesoul"
        target="_blank"
        rel="noopener noreferrer"
        class:list={['flex items-center gap-2 transition-colors', linkClasses]}
      >
        <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        facebook.com/rhythmforthesoul
      </a>
    </div>
  )}
</div>

<script>
  document.querySelectorAll('[data-contact-form]').forEach((formEl) => {
    const form = formEl as HTMLFormElement;
    const wrapper = form.closest('[data-form-wrapper]')!;
    const btn    = form.querySelector('[data-submit-btn]') as HTMLButtonElement;
    const okMsg  = wrapper.querySelector('[data-success-msg]') as HTMLElement;
    const errMsg = wrapper.querySelector('[data-error-msg]') as HTMLElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Let the browser run HTML5 constraint validation first
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const label = btn.textContent ?? 'Send Message';
      btn.textContent = 'Sending…';
      btn.disabled = true;
      okMsg.classList.add('hidden');
      errMsg.classList.add('hidden');

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          form.reset();
          okMsg.classList.remove('hidden');
          btn.textContent = 'Sent ✓';
        } else {
          const payload = await res.json().catch(() => ({}));
          throw new Error((payload as { error?: string }).error ?? 'Server error');
        }
      } catch {
        errMsg.classList.remove('hidden');
        btn.textContent = label;
        btn.disabled = false;
      }
    });
  });
</script>
